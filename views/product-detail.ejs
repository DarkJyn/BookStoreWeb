<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<main class="max-w-container-max mx-auto px-margin-desktop py-12">

<!-- Breadcrumbs -->
<nav class="flex items-center gap-2 mb-12 text-on-surface-variant font-label-md">
<a class="hover:text-primary" href="/products">Catalog</a>
<span class="material-symbols-outlined text-base">chevron_right</span>
<a class="hover:text-primary" href="/products?genre=<%= encodeURIComponent(book.genre) %>"><%= book.genre %></a>
<span class="material-symbols-outlined text-base">chevron_right</span>
<span class="text-primary font-bold"><%= book.title %></span>
</nav>
<section class="grid grid-cols-1 md:grid-cols-12 gap-gutter-desktop mb-20">
<!-- Left: Large high-quality book cover -->
<div class="md:col-span-5">
<div class="aspect-[3/4] rounded-lg overflow-hidden book-card-shadow bg-surface-container-low group">
<img alt="<%= book.title %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-alt="<%= book.imageAlt %>" src="<%= book.coverImage %>">
</div>
<div class="mt-6 flex gap-4">
<button onclick="openPreviewModal()" class="flex-1 border border-outline-variant py-3 rounded-lg flex items-center justify-center gap-2 text-on-surface font-label-md hover:bg-surface-container-low transition-all">
<span class="material-symbols-outlined">zoom_in</span> View Preview
                    </button>
<button onclick="copyProductLink(this)" class="px-4 border border-outline-variant rounded-lg hover:bg-surface-container-low transition-all" title="Sao chép liên kết">
<span class="material-symbols-outlined">share</span>
</button>
</div>
</div>
<!-- Right: Book Info & Purchase Area -->
<div class="md:col-span-7 flex flex-col">
<div class="mb-4">
<span class="inline-flex items-center px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full font-label-md text-xs mb-4">
                        <%= book.stockStatus %>
                    </span>
<h1 class="font-display-lg text-display-lg text-primary mb-2"><%= book.title %></h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-6">by <a class="text-primary underline underline-offset-4 decoration-outline-variant hover:decoration-primary transition-all" href="/products?author=<%= encodeURIComponent(book.author) %>"><%= book.author %></a></p>
</div>
<div class="grid grid-cols-2 gap-y-4 mb-8 pb-8 border-b border-outline-variant">
<div>
<p class="font-label-md text-on-surface-variant text-caption">Genre</p>
<p class="font-body-md text-on-surface"><%= book.genre %></p>
</div>
<div>
<p class="font-label-md text-on-surface-variant text-caption">Publisher</p>
<p class="font-body-md text-on-surface"><%= book.publisher %></p>
</div>
<div>
<p class="font-label-md text-on-surface-variant text-caption">Year</p>
<p class="font-body-md text-on-surface"><%= book.year %></p>
</div>
<div>
<p class="font-label-md text-on-surface-variant text-caption">Format</p>
<p class="font-body-md text-on-surface"><%= book.format %></p>
</div>
</div>
<div class="mb-8">
<div class="flex items-baseline gap-4 mb-6">
<span class="font-display-lg text-headline-lg text-primary"><%= formatPrice(book.price) %></span>
<% if (book.originalPrice) { %>
<span class="font-body-md text-on-surface-variant line-through"><%= formatPrice(book.originalPrice) %></span>
<% } %>
</div>
<div class="flex flex-wrap gap-4 items-end">
<div class="flex flex-col gap-2">
<label class="font-label-md text-caption text-on-surface-variant">Quantity</label>
<div class="flex items-center border border-outline-variant rounded-lg bg-white h-12">
<button class="px-3 hover:text-primary"><span class="material-symbols-outlined text-base">remove</span></button>
<span class="px-4 font-body-md">1</span>
<button class="px-3 hover:text-primary"><span class="material-symbols-outlined text-base">add</span></button>
</div>
</div>
<button class="flex-grow h-12 bg-primary text-on-primary rounded-lg font-label-md hover:bg-primary-container transition-all flex items-center justify-center gap-2" 
        data-book="<%= JSON.stringify(book) %>" 
        onclick="if(typeof addToCart === 'function') { addToCart(JSON.parse(this.getAttribute('data-book'))); window.location.href='/cart'; }">
<span class="material-symbols-outlined text-xl" data-weight="fill">shopping_bag</span> Buy Now
                        </button>
</div>
<div class="mt-4">
<button class="w-full h-12 border border-primary text-primary rounded-lg font-label-md hover:bg-surface-container-low transition-all flex items-center justify-center gap-2" 
        data-book="<%= JSON.stringify(book) %>" 
        onclick="if(typeof addToCart === 'function') addToCart(JSON.parse(this.getAttribute('data-book')))">
                            Add to Cart
                        </button>
</div>
</div>
</div>
</section>
<!-- Description Section: Tabbed interface -->
<section class="mb-20">
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter-desktop">
  <!-- Left Side: Description -->
  <div class="md:col-span-6 space-y-6">
    <h3 class="font-headline-md text-headline-md text-primary border-b border-outline-variant pb-4">Mô tả sản phẩm</h3>
    <% if (book.description && book.description.length > 0) { %>
      <% book.description.forEach(paragraph => { %>
        <p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">
            <%= paragraph %>
        </p>
      <% }); %>
    <% } else { %>
      <p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">Cập nhật sau</p>
    <% } %>
  </div>

  <!-- Right Side: Details -->
  <div class="md:col-span-6 space-y-6">
    <h3 class="font-headline-md text-headline-md text-primary border-b border-outline-variant pb-4">Thông tin chi tiết</h3>
    <div class="space-y-0.5 border-t border-outline-variant/30">
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Mã hàng</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.product_code || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Độ Tuổi</div>
        <div class="col-span-7 text-primary font-body-md font-medium"><%= book.age_range || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Tên Nhà Cung Cấp</div>
        <div class="col-span-7 text-primary font-body-md font-medium"><%= book.supplier_name || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Tác giả</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.author || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">NXB</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.publisher || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Năm XB</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.year || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Ngôn Ngữ</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.language || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Trọng lượng (gr)</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.weight ? book.weight + ' gr' : 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Kích Thước Bao Bì</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.size || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 border-b border-outline-variant/30 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Số trang</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.pages || 'Cập nhật sau' %></div>
      </div>
      <div class="grid grid-cols-12 py-3 items-center">
        <div class="col-span-5 text-on-surface-variant font-label-md">Hình thức</div>
        <div class="col-span-7 text-on-surface font-body-md font-medium"><%= book.format || 'Cập nhật sau' %></div>
      </div>
    </div>
  </div>
</div>
</section>
<!-- Related Books -->
<section class="border-t border-outline-variant pt-20">
<div class="flex justify-between items-center mb-10">
<h2 class="font-display-lg text-headline-lg text-primary">You May Also Enjoy</h2>
<div class="flex gap-2">
<button class="w-10 h-10 border border-outline-variant rounded-full flex items-center justify-center hover:bg-surface-container transition-all">
<span class="material-symbols-outlined">chevron_left</span>
</button>
<button class="w-10 h-10 border border-outline-variant rounded-full flex items-center justify-center hover:bg-surface-container transition-all">
<span class="material-symbols-outlined">chevron_right</span>
</button>
</div>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-gutter-desktop">
<% relatedBooks.forEach(relatedBook => { %>
    <div class="group">
        <a href="/products/<%= relatedBook.id %>" class="aspect-[3/4] mb-4 overflow-hidden rounded-lg book-card-shadow bg-surface-container-low block">
            <img alt="<%= relatedBook.title %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="<%= relatedBook.imageAlt %>" src="<%= relatedBook.coverImage %>">
        </a>
        <a href="/products/<%= relatedBook.id %>" class="font-headline-md text-body-md text-on-surface group-hover:text-primary transition-colors hover:underline block truncate"><%= relatedBook.title %></a>
        <p class="font-body-md text-caption text-on-surface-variant"><%= relatedBook.author %></p>
        <p class="font-label-md text-primary mt-1"><%= formatPrice(relatedBook.price) %></p>
    </div>
<% }); %>
</div>
</section>

</main>

<!-- Modal for Book Cover Zoom -->
<div id="previewModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/85 backdrop-blur-sm cursor-pointer" onclick="closePreviewModal()">
  <div class="relative max-w-[90vw] max-h-[90vh] bg-surface-container-lowest rounded-xl p-3 shadow-2xl cursor-default border border-outline-variant/30 animate-[zoomIn_0.2s_ease-out]" onclick="event.stopPropagation()">
    <button onclick="closePreviewModal()" class="absolute top-4 right-4 w-10 h-10 rounded-full bg-black/50 text-white flex items-center justify-center hover:bg-black/70 hover:scale-105 active:scale-95 transition-all">
      <span class="material-symbols-outlined">close</span>
    </button>
    <img src="<%= book.coverImage %>" alt="<%= book.title %>" class="max-w-full max-h-[80vh] object-contain rounded-lg shadow-lg">
  </div>
</div>

<style>
  @keyframes zoomIn {
    from {
      opacity: 0;
      transform: scale(0.95);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script>
  function openPreviewModal() {
    const modal = document.getElementById('previewModal');
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closePreviewModal() {
    const modal = document.getElementById('previewModal');
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function copyProductLink(btn) {
    const link = window.location.href;
    navigator.clipboard.writeText(link).then(() => {
      // Show checkmark icon temporarily
      const originalInner = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined text-green-600">done</span>';
      btn.classList.add('border-green-600');
      
      // Temporary tooltip feedback
      setTimeout(() => {
        btn.innerHTML = originalInner;
        btn.classList.remove('border-green-600');
      }, 2000);
    }).catch(err => {
      console.error('Failed to copy link: ', err);
      // Fallback
      const tempInput = document.createElement('input');
      tempInput.value = link;
      document.body.appendChild(tempInput);
      tempInput.select();
      document.execCommand('copy');
      document.body.removeChild(tempInput);
      
      const originalInner = btn.innerHTML;
      btn.innerHTML = '<span class="material-symbols-outlined text-green-600">done</span>';
      setTimeout(() => {
        btn.innerHTML = originalInner;
      }, 2000);
    });
  }
</script>

<%- include('partials/footer') %>
