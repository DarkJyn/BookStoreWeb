<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<main class="max-w-container-max mx-auto px-margin-desktop py-12">

<!-- Breadcrumbs -->
<nav class="flex items-center gap-2 mb-12 text-on-surface-variant font-label-md">
<a class="hover:text-primary" href="/products">Catalog</a>
<span class="material-symbols-outlined text-base">chevron_right</span>
<a class="hover:text-primary" href="/products?genre=<%= encodeURIComponent(book.genre) %>"><%= book.genre %></a>
<span class="material-symbols-outlined text-base">chevron_right</span>
<span class="text-primary font-bold"><%= book.title %></span>
</nav>
<section class="grid grid-cols-1 md:grid-cols-12 gap-gutter-desktop mb-20">
<!-- Left: Large high-quality book cover -->
<div class="md:col-span-5">
<div class="aspect-[3/4] rounded-lg overflow-hidden book-card-shadow bg-surface-container-low group">
<img alt="<%= book.title %>" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" data-alt="<%= book.imageAlt %>" src="<%= book.coverImage %>">
</div>
<div class="mt-6 flex gap-4">
<button class="flex-1 border border-outline-variant py-3 rounded-lg flex items-center justify-center gap-2 text-on-surface font-label-md hover:bg-surface-container-low transition-all">
<span class="material-symbols-outlined">zoom_in</span> View Preview
                    </button>
<button class="px-4 border border-outline-variant rounded-lg hover:bg-surface-container-low transition-all">
<span class="material-symbols-outlined">share</span>
</button>
</div>
</div>
<!-- Right: Book Info & Purchase Area -->
<div class="md:col-span-7 flex flex-col">
<div class="mb-4">
<span class="inline-flex items-center px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full font-label-md text-xs mb-4">
                        <%= book.stockStatus %>
                    </span>
<h1 class="font-display-lg text-display-lg text-primary mb-2"><%= book.title %></h1>
<p class="font-body-lg text-body-lg text-on-surface-variant mb-6">by <a class="text-primary underline underline-offset-4 decoration-outline-variant hover:decoration-primary transition-all" href="/products?author=<%= encodeURIComponent(book.author) %>"><%= book.author %></a></p>
</div>
<div class="grid grid-cols-2 gap-y-4 mb-8 pb-8 border-b border-outline-variant">
<div>
<p class="font-label-md text-on-surface-variant text-caption">Genre</p>
<p class="font-body-md text-on-surface"><%= book.genre %></p>
</div>
<div>
<p class="font-label-md text-on-surface-variant text-caption">Publisher</p>
<p class="font-body-md text-on-surface"><%= book.publisher %></p>
</div>
<div>
<p class="font-label-md text-on-surface-variant text-caption">Year</p>
<p class="font-body-md text-on-surface"><%= book.year %></p>
</div>
<div>
<p class="font-label-md text-on-surface-variant text-caption">Format</p>
<p class="font-body-md text-on-surface"><%= book.format %></p>
</div>
</div>
<div class="mb-8">
<div class="flex items-baseline gap-4 mb-6">
<span class="font-display-lg text-headline-lg text-primary"><%= formatPrice(book.price) %></span>
<% if (book.originalPrice) { %>
<span class="font-body-md text-on-surface-variant line-through"><%= formatPrice(book.originalPrice) %></span>
<% } %>
</div>
<div class="flex flex-wrap gap-4 items-end">
<div class="flex flex-col gap-2">
<label class="font-label-md text-caption text-on-surface-variant">Quantity</label>
<div class="flex items-center border border-outline-variant rounded-lg bg-white h-12">
<button class="px-3 hover:text-primary"><span class="material-symbols-outlined text-base">remove</span></button>
<span class="px-4 font-body-md">1</span>
<button class="px-3 hover:text-primary"><span class="material-symbols-outlined text-base">add</span></button>
</div>
</div>
<button class="flex-grow h-12 bg-primary text-on-primary rounded-lg font-label-md hover:bg-primary-container transition-all flex items-center justify-center gap-2" 
        data-book="<%= JSON.stringify(book) %>" 
        onclick="if(typeof addToCart === 'function') { addToCart(JSON.parse(this.getAttribute('data-book'))); window.location.href='/cart'; }">
<span class="material-symbols-outlined text-xl" data-weight="fill">shopping_bag</span> Buy Now
                        </button>
</div>
<div class="grid grid-cols-2 gap-4 mt-4">
<button class="h-12 border border-primary text-primary rounded-lg font-label-md hover:bg-surface-container-low transition-all flex items-center justify-center gap-2" 
        data-book="<%= JSON.stringify(book) %>" 
        onclick="if(typeof addToCart === 'function') addToCart(JSON.parse(this.getAttribute('data-book')))">
                            Add to Cart
                        </button>
<button class="h-12 border border-outline-variant text-on-surface-variant rounded-lg font-label-md hover:bg-surface-container-low transition-all flex items-center justify-center gap-2">
<span class="material-symbols-outlined text-xl">favorite</span> Add to Wishlist
                        </button>
</div>
</div>
<!-- Shipping / Trust -->
<div class="bg-surface-container-low p-4 rounded-lg space-y-3">
<div class="flex items-center gap-3 text-on-surface-variant">
<span class="material-symbols-outlined text-secondary">local_shipping</span>
<p class="text-caption">Miễn phí vận chuyển cho đơn hàng từ 500.000 đ. Nhận hàng trong 3-5 ngày làm việc.</p>
</div>
<div class="flex items-center gap-3 text-on-surface-variant">
<span class="material-symbols-outlined text-secondary">verified</span>
<p class="text-caption">Includes a complimentary Folio bookmark and protective sleeve.</p>
</div>
</div>
</div>
</section>
<!-- Description Section: Tabbed interface -->
<section class="mb-20">
<div class="border-b border-outline-variant mb-8">
<nav class="flex gap-12">
<button class="pb-4 text-primary font-label-md border-b-2 border-primary">Description</button>
<button class="pb-4 text-on-surface-variant font-label-md hover:text-primary transition-colors">Details</button>
<button class="pb-4 text-on-surface-variant font-label-md hover:text-primary transition-colors">Reviews (128)</button>
</nav>
</div>
<div class="grid grid-cols-1 md:grid-cols-12 gap-gutter-desktop">
<div class="md:col-span-12 space-y-6">
<h3 class="font-headline-md text-headline-md text-primary"><%= book.title %></h3>
<% book.description.forEach(paragraph => { %>
<p class="font-body-lg text-body-lg text-on-surface-variant leading-relaxed">
    <%= paragraph %>
</p>
<% }); %>
</div>
</div>
</section>
<!-- Related Books -->
<section class="border-t border-outline-variant pt-20">
<div class="flex justify-between items-center mb-10">
<h2 class="font-display-lg text-headline-lg text-primary">You May Also Enjoy</h2>
<div class="flex gap-2">
<button class="w-10 h-10 border border-outline-variant rounded-full flex items-center justify-center hover:bg-surface-container transition-all">
<span class="material-symbols-outlined">chevron_left</span>
</button>
<button class="w-10 h-10 border border-outline-variant rounded-full flex items-center justify-center hover:bg-surface-container transition-all">
<span class="material-symbols-outlined">chevron_right</span>
</button>
</div>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-gutter-desktop">
<% relatedBooks.forEach(relatedBook => { %>
    <div class="group">
        <a href="/products/<%= relatedBook.id %>" class="aspect-[3/4] mb-4 overflow-hidden rounded-lg book-card-shadow bg-surface-container-low block">
            <img alt="<%= relatedBook.title %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" data-alt="<%= relatedBook.imageAlt %>" src="<%= relatedBook.coverImage %>">
        </a>
        <a href="/products/<%= relatedBook.id %>" class="font-headline-md text-body-md text-on-surface group-hover:text-primary transition-colors hover:underline block truncate"><%= relatedBook.title %></a>
        <p class="font-body-md text-caption text-on-surface-variant"><%= relatedBook.author %></p>
        <p class="font-label-md text-primary mt-1"><%= formatPrice(relatedBook.price) %></p>
    </div>
<% }); %>
</div>
</section>

</main>

<%- include('partials/footer') %>
