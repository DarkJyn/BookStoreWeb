<%- include('partials/head', { title: 'Đăng nhập' }) %>
<%- include('partials/header', { activePage: 'login' }) %>

<style>
  .form-input-focus:focus {
      border-color: #4a321d;
      box-shadow: 0 0 0 1px #4a321d;
  }
  .card-shadow {
      box-shadow: 0px 4px 20px rgba(74, 69, 65, 0.06);
  }
  .book-texture {
      background-image: radial-gradient(#eae1db 0.5px, transparent 0.5px);
      background-size: 24px 24px;
  }
</style>

<main class="flex-grow flex items-center justify-center py-12 px-margin-mobile bg-surface-container-low book-texture min-h-[calc(100vh-160px)]">
  <div class="w-full max-w-[1000px] grid grid-cols-1 md:grid-cols-2 bg-surface-container-lowest rounded-xl overflow-hidden card-shadow">
      <!-- Branding/Image Panel (Left Side) -->
      <div class="relative hidden md:flex flex-col justify-end p-12 bg-primary overflow-hidden">
          <img class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-multiply" data-alt="Library Image" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCg2G7z2RjRtwsljRLzyqcXKNSRGcbFuJmzpVeswIT7R2GVm5zFS68Hra2EUgA6CHmxVppMbsx9fUyJvhlQpzLHbBZLMK7wDmyZeGMrwTm5l9n6uMDacea6Re-H1dLBpJMR5aYLdsoWhaQnl2D65sNxW37lkOELYUaxQrEpmCu7HZVY9v0Nos-j8uYONG1uJfDg5OqZ6UOqPpQRsOQ2L_6UaBhaaV2ITcO7MDZgoPYetwwYnndq5zDZLzmiQh7gKfM7pG6_YcFPxuo"/>
          <div class="relative z-10 text-on-primary">
              <h1 class="font-display-lg text-display-lg mb-4">The Open Folio</h1>
              <p class="font-body-lg text-body-lg text-primary-fixed-dim max-w-sm">Step back into the world of tactile stories and curated knowledge.</p>
          </div>
          <!-- Decorative element -->
          <div class="absolute top-0 right-0 p-8 opacity-20">
              <span class="material-symbols-outlined text-[120px]" data-icon="auto_stories">auto_stories</span>
          </div>
      </div>

      <!-- Form Panel (Right Side) -->
      <div class="p-8 md:p-16 flex flex-col">
          <div class="mb-10">
              <h2 class="font-headline-lg text-headline-lg text-on-surface mb-2">Welcome Back</h2>
              <p class="text-on-surface-variant">Sign in to access your personal collection.</p>
              <% if (typeof error !== 'undefined' && error) { %>
                  <p class="text-error font-medium mt-2"><%= error %></p>
              <% } %>
          </div>

          <!-- Login Form -->
          <form action="/login" class="space-y-6" method="POST">
              <!-- Username/Email -->
              <div class="space-y-1">
                  <label class="font-label-md text-label-md text-on-surface-variant" for="email">Email</label>
                  <div class="relative">
                      <input class="w-full h-12 bg-surface-bright border border-outline-variant rounded-lg px-4 font-body-md text-on-surface placeholder:text-outline focus:outline-none form-input-focus transition-all" id="email" name="email" placeholder="reader@openfolio.com" required type="email"/>
                  </div>
              </div>
              <!-- Password -->
              <div class="space-y-1">
                  <div class="flex justify-between items-center">
                      <label class="font-label-md text-label-md text-on-surface-variant" for="password">Password</label>
                      <a class="font-label-md text-primary hover:underline transition-all" href="#">Forgot password?</a>
                  </div>
                  <div class="relative">
                      <input class="w-full h-12 bg-surface-bright border border-outline-variant rounded-lg px-4 font-body-md text-on-surface placeholder:text-outline focus:outline-none form-input-focus transition-all" id="password" name="password" placeholder="••••••••" required type="password"/>
                      <button class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant" type="button" id="togglePassword">
                          <span class="material-symbols-outlined text-[20px]" id="eyeIcon">visibility_off</span>
                      </button>
                  </div>
              </div>
              <!-- Remember Me -->
              <div class="flex items-center space-x-2 ml-1">
                  <input class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary bg-surface-container-low" id="remember" name="remember" type="checkbox"/>
                  <label class="font-body-md text-on-surface-variant select-none" for="remember">Remember me for 30 days</label>
              </div>

              <!-- Submit Button -->
              <input type="hidden" name="redirectUrl" value="<%= typeof redirectUrl !== 'undefined' ? redirectUrl : '' %>">
              <button class="w-full h-12 bg-primary text-on-primary font-label-md text-label-md rounded-lg shadow-sm hover:opacity-90 active:scale-[0.98] transition-all flex items-center justify-center gap-2" type="submit">
                  Sign In
                  <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
              </button>
          </form>

          <!-- Footer Link -->
          <div class="mt-12 pt-6 border-t border-outline-variant text-center">
              <p class="font-body-md text-on-surface-variant">
                  New to the folio? 
                  <a class="text-primary font-bold hover:underline ml-1" href="/register">Create an account</a>
              </p>
          </div>
      </div>
  </div>
</main>

<script>
    const toggleBtn = document.getElementById('togglePassword');
    const passInput = document.getElementById('password');
    const eyeIcon = document.getElementById('eyeIcon');
    toggleBtn.addEventListener('click', () => {
        const isPass = passInput.type === 'password';
        passInput.type = isPass ? 'text' : 'password';
        eyeIcon.textContent = isPass ? 'visibility' : 'visibility_off';
    });
</script>

<%- include('partials/footer') %>