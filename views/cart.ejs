                <div class="bg-surface-container-lowest rounded-xl p-16 text-center shadow-[0px_4px_20px_rgba(74,69,65,0.06)]">
                    <span class="material-symbols-outlined text-6xl text-outline-variant mb-6" data-icon="shopping_basket">shopping_basket</span>
                    <h2 class="font-display-lg text-headline-lg text-primary mb-4">Your cart is empty</h2>
                    <p class="font-body-md text-on-surface-variant mb-8 max-w-sm mx-auto">It seems you haven't discovered any treasures yet. Our shelves are full of waiting stories.</p>
                    <button class="px-8 py-3 bg-primary text-on-primary rounded-lg font-label-md hover:bg-primary-container hover:text-on-primary-container transition-all">Start Shopping</button>
                </div>
                -->
</div>
<!-- Summary Panel -->
<div class="lg:col-span-4 space-y-gutter-desktop">
<div class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_20px_rgba(74,69,65,0.06)] p-8">
<h2 class="font-headline-md text-primary mb-6">Order Summary</h2>
<div class="space-y-4 mb-6">
<div class="flex justify-between font-body-md">
<span class="text-on-surface-variant">Subtotal</span>
<span class="text-on-surface">570.000 đ</span>
</div>
<div class="flex justify-between font-body-md">
<span class="text-on-surface-variant">Shipping</span>
<span class="text-on-surface">Calculated at next step</span>
</div>
<div class="flex justify-between font-body-md">
<span class="text-on-surface-variant">Estimated Tax</span>
<span class="text-on-surface">57.000 đ</span>
</div>
</div>
<div class="mb-6 pt-6 border-t border-outline-variant">
<label class="font-label-md text-on-surface-variant block mb-2">Discount Code</label>
<div class="flex space-x-2">
<input class="flex-1 bg-surface-container-low border border-outline-variant rounded-lg px-4 py-2 text-body-md focus:border-primary outline-none" placeholder="Enter code" type="text">
<button class="px-4 py-2 bg-secondary text-on-secondary rounded-lg font-label-md hover:opacity-90 transition-opacity">Apply</button>
</div>
</div>
<div class="flex justify-between items-end mb-8">
<div>
<span class="font-headline-md text-primary">Total</span>
<p class="font-caption text-on-surface-variant">Including taxes</p>
</div>
<span class="text-3xl font-display-lg text-primary">627.000 đ</span>
</div>
<button class="w-full py-4 bg-primary text-on-primary rounded-lg font-label-md text-lg hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center space-x-2 mb-4">
<span>Proceed to Checkout</span>
<span class="material-symbols-outlined text-sm" data-icon="lock">lock</span>
</button>
<div class="flex items-center justify-center space-x-4">
<span class="material-symbols-outlined text-outline-variant" data-icon="credit_card">credit_card</span>
<span class="material-symbols-outlined text-outline-variant" data-icon="payments">payments</span>
<span class="material-symbols-outlined text-outline-variant" data-icon="account_balance_wallet">account_balance_wallet</span>
</div>
</div>
<!-- Trust Badge Area -->
<div class="bg-surface-container-low rounded-xl p-6 border border-outline-variant">
<div class="flex items-start space-x-4">
<span class="material-symbols-outlined text-secondary" data-icon="verified">verified</span>
<div>
<h4 class="font-label-md text-primary">The Folio Guarantee</h4>
<p class="font-caption text-on-surface-variant mt-1">Every book is inspected for quality. 30-day easy returns on all physical orders.</p>
</div>
</div>
</div>
</div>
</div>

</main>

<%- include('partials/footer') %>
