<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 min-h-screen">

<!-- Page Title -->
<div class="mb-10">
  <h1 class="font-display-lg text-display-lg text-primary mb-2">Giỏ hàng của bạn</h1>
  <p class="font-body-md text-body-md text-on-surface-variant">Xem lại các cuốn sách bạn đã chọn.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter-desktop items-start">

  <!-- ===== LEFT: CART TABLE ===== -->
  <div class="lg:col-span-8">

    <!-- EMPTY STATE -->
    <div id="cart-empty" class="hidden bg-surface-container-lowest rounded-xl p-16 text-center shadow-[0px_4px_20px_rgba(74,69,65,0.06)]">
      <span class="material-symbols-outlined text-[72px] text-outline-variant mb-6 block" style="font-variation-settings:'FILL' 0">shopping_basket</span>
      <h2 class="font-headline-lg text-primary mb-4">Giỏ hàng trống</h2>
      <p class="font-body-md text-on-surface-variant mb-8 max-w-sm mx-auto">Bạn chưa thêm cuốn sách nào. Hãy khám phá kho sách của chúng tôi!</p>
      <a href="/products" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-on-primary rounded-lg font-label-md hover:opacity-90 active:scale-95 transition-all">
        <span class="material-symbols-outlined text-[18px]">storefront</span>
        Khám phá sách
      </a>
    </div>

    <!-- CART TABLE -->
    <div id="cart-filled" class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_20px_rgba(74,69,65,0.06)] overflow-hidden">
      <!-- Table Header (Desktop) -->
      <div class="hidden md:grid grid-cols-12 gap-2 px-8 py-4 border-b border-outline-variant bg-surface-container-low font-label-md text-on-surface-variant text-sm">
        <div class="col-span-5">Chi tiết sách</div>
        <div class="col-span-2 text-center">Đơn giá</div>
        <div class="col-span-3 text-center">Số lượng</div>
        <div class="col-span-2 text-right pr-14">Thành tiền</div>
      </div>

      <!-- Dynamic Items -->
      <div id="cart-items-container"></div>

      <!-- Footer Actions -->
      <div class="px-6 md:px-8 py-5 flex justify-between items-center bg-surface-container-low border-t border-outline-variant">
        <a href="/products" class="flex items-center gap-2 text-on-surface-variant hover:text-primary transition-colors font-label-md">
          <span class="material-symbols-outlined text-[18px]">arrow_back</span>
          Tiếp tục mua sắm
        </a>
        <button id="clear-btn" onclick="openClearModal()" class="flex items-center gap-1 text-error hover:underline font-label-md transition-colors">
          <span class="material-symbols-outlined text-[18px]">delete_sweep</span>
          Xóa tất cả
        </button>
      </div>
    </div>
  </div>

  <!-- ===== RIGHT: ORDER SUMMARY ===== -->
  <div class="lg:col-span-4 space-y-4">
    <div class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_20px_rgba(74,69,65,0.06)] p-8">
      <h2 class="font-headline-md text-primary mb-6">Tóm tắt đơn hàng</h2>

      <!-- Line Items -->
      <div class="space-y-3 mb-6">
        <div class="flex justify-between font-body-md">
          <span class="text-on-surface-variant">Tạm tính</span>
          <span id="summary-subtotal" class="text-on-surface">0 đ</span>
        </div>

        <div class="flex justify-between font-body-md">
          <span class="text-on-surface-variant">Thuế (10%)</span>
          <span id="summary-tax" class="text-on-surface">0 đ</span>
        </div>
        <div class="flex justify-between font-body-md">
          <span class="text-on-surface-variant">Phí giao hàng</span>
          <span class="text-on-surface-variant italic text-sm">Tính ở bước tiếp theo</span>
        </div>
      </div>



      <!-- Total -->
      <div class="flex justify-between items-end mb-8 pt-5 border-t border-outline-variant">
        <div>
          <span class="font-headline-md text-primary">Tổng cộng</span>
          <p class="font-caption text-on-surface-variant">Đã bao gồm thuế</p>
        </div>
        <span id="summary-total" class="text-3xl font-display-lg text-primary">0 đ</span>
      </div>

      <!-- Checkout Button -->
      <a id="checkout-btn" href="/checkout"
        class="w-full py-4 bg-primary text-on-primary rounded-lg font-label-md text-lg hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2 mb-4">
        <span>Tiến hành thanh toán</span>
        <span class="material-symbols-outlined text-[18px]">lock</span>
      </a>

      <div class="flex items-center justify-center gap-4 text-outline-variant">
        <span class="material-symbols-outlined">credit_card</span>
        <span class="material-symbols-outlined">payments</span>
        <span class="material-symbols-outlined">account_balance_wallet</span>
      </div>
    </div>

  </div>

</div>
</main>

<script>


// ============ FORMAT ============
function fmtVND(amount) {
  return new Intl.NumberFormat('vi-VN').format(Math.round(amount)) + ' đ';
}

// ============ RENDER CART ============
function renderCart() {
  const cart      = getCart();
  const emptyEl   = document.getElementById('cart-empty');
  const filledEl  = document.getElementById('cart-filled');
  const container = document.getElementById('cart-items-container');

  if (!cart || cart.length === 0) {
    emptyEl.classList.remove('hidden');
    filledEl.classList.add('hidden');
    updateSummary(0);
    return;
  }

  emptyEl.classList.add('hidden');
  filledEl.classList.remove('hidden');

  container.innerHTML = cart.map(item => `
    <div class="grid grid-cols-12 gap-2 px-6 md:px-8 py-6 border-b border-outline-variant items-center group transition-colors hover:bg-surface-container-lowest/50"
         data-item-id="${item.id}">

      <!-- Book Detail -->
      <div class="col-span-12 md:col-span-5 flex items-center gap-4">
        <a href="/products/${item.id}"
           class="w-20 h-28 flex-shrink-0 bg-surface-container overflow-hidden rounded-lg shadow-sm block hover:shadow-md transition-shadow">
          <img class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
               src="${item.coverImage || ''}"
               alt="${escHtml(item.title)}"
               onerror="this.style.display='none'">
        </a>
        <div class="min-w-0">
          <a href="/products/${item.id}"
             class="font-headline-md text-primary leading-tight mb-1 hover:underline block line-clamp-2">
            ${escHtml(item.title)}
          </a>
          <p class="font-body-md text-on-surface-variant text-sm mb-2">${escHtml(item.author || '')}</p>
          ${item.genre ? `<span class="font-caption text-on-tertiary-fixed-variant px-2 py-0.5 bg-tertiary-fixed inline-block rounded text-xs uppercase tracking-wide">${escHtml(item.genre)}</span>` : ''}
        </div>
      </div>

      <!-- Unit Price -->
      <div class="col-span-6 md:col-span-2 text-left md:text-center">
        <span class="md:hidden text-xs text-on-surface-variant block mb-1">Đơn giá</span>
        <span class="font-body-md text-on-surface whitespace-nowrap">${fmtVND(item.price)}</span>
      </div>

      <!-- Quantity Stepper -->
      <div class="col-span-6 md:col-span-3 flex justify-start md:justify-center">
        <div class="inline-flex items-center border border-outline-variant rounded-lg overflow-hidden h-10">
          <button onclick="handleUpdateQty('${item.id}', -1)"
                  class="px-2 hover:bg-surface-container transition-colors h-full flex items-center text-on-surface-variant hover:text-primary"
                  aria-label="Giảm số lượng">
            <span class="material-symbols-outlined text-[18px]">remove</span>
          </button>
          <span class="px-3 font-label-md min-w-[2rem] text-center select-none">${item.quantity}</span>
          <button onclick="handleUpdateQty('${item.id}', 1)"
                  class="px-2 hover:bg-surface-container transition-colors h-full flex items-center text-on-surface-variant hover:text-primary"
                  aria-label="Tăng số lượng">
            <span class="material-symbols-outlined text-[18px]">add</span>
          </button>
        </div>
      </div>

      <!-- Subtotal + Delete (price never shifts: w-8 placeholder always reserves space) -->
      <div class="col-span-12 md:col-span-2 flex items-center justify-end">
        <span class="font-label-md text-primary whitespace-nowrap">${fmtVND(item.price * item.quantity)}</span>
        <div class="w-12 flex-shrink-0 flex justify-end">
          <button onclick="handleRemove('${item.id}')"
                  class="text-on-surface-variant hover:text-error transition-all p-1 rounded-lg opacity-0 group-hover:opacity-100 hover:bg-error-container"
                  aria-label="Xóa">
            <span class="material-symbols-outlined text-[20px]">delete</span>
          </button>
        </div>
      </div>
    </div>
  `).join('');

  updateSummary(getCartTotal());
}

// Escape HTML to prevent XSS
function escHtml(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;');
}

// ============ SUMMARY ============
function updateSummary(subtotal) {
  const tax   = subtotal * 0.10;
  const total = subtotal + tax;

  document.getElementById('summary-subtotal').textContent = fmtVND(subtotal);
  document.getElementById('summary-tax').textContent      = fmtVND(tax);
  document.getElementById('summary-total').textContent    = fmtVND(total);
}

// ============ EVENT HANDLERS ============
function handleUpdateQty(id, delta) {
  updateQuantity(id, delta);
  renderCart();
}

function handleRemove(id) {
  removeFromCart(id);
  renderCart();
  if (typeof showToast === 'function') showToast('Đã xóa khỏi giỏ hàng.', 'info');
}

function handleClearCart() {
  clearCart();
  renderCart();
}

document.addEventListener('DOMContentLoaded', function () {
  // Close modal on backdrop click
  document.getElementById('clear-modal-backdrop').addEventListener('click', function(e) {
    if (e.target === this) closeClearModal();
  });

  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeClearModal();
  });

  // Initial render (cart.js is loaded via footer, should be ready)
  renderCart();
});

// ============ CLEAR CART MODAL ============
function openClearModal() {
  const modal    = document.getElementById('clear-modal-backdrop');
  const card     = document.getElementById('clear-modal-card');
  modal.classList.remove('hidden');
  // Trigger animation next frame
  requestAnimationFrame(() => {
    modal.classList.add('modal-visible');
    card.classList.add('card-visible');
  });
}

function closeClearModal() {
  const modal = document.getElementById('clear-modal-backdrop');
  const card  = document.getElementById('clear-modal-card');
  modal.classList.remove('modal-visible');
  card.classList.remove('card-visible');
  setTimeout(() => modal.classList.add('hidden'), 250);
}

function confirmClearCart() {
  closeClearModal();
  setTimeout(() => {
    clearCart();
    renderCart();
    if (typeof showToast === 'function') showToast('Đã xóa toàn bộ giỏ hàng.', 'info');
  }, 260);
}
</script>

<!-- ===== CLEAR CART CONFIRM MODAL ===== -->
<div id="clear-modal-backdrop"
     class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4"
     style="background: rgba(0,0,0,0); backdrop-filter: blur(0px); transition: background 0.25s ease, backdrop-filter 0.25s ease;">

  <div id="clear-modal-card"
       class="relative bg-surface-container-lowest rounded-2xl shadow-2xl w-full max-w-md p-8 border border-outline-variant"
       style="opacity: 0; transform: translateY(20px) scale(0.97); transition: opacity 0.25s ease, transform 0.25s ease;">

    <!-- Icon -->
    <div class="flex justify-center mb-5">
      <div class="w-16 h-16 rounded-full bg-error-container flex items-center justify-center">
        <span class="material-symbols-outlined text-error text-[36px]"
              style="font-variation-settings:'FILL' 1">delete_sweep</span>
      </div>
    </div>

    <!-- Text -->
    <h3 class="font-headline-md text-on-surface text-center mb-2">Xóa toàn bộ giỏ hàng?</h3>
    <p class="font-body-md text-on-surface-variant text-center mb-8">
      Tất cả sản phẩm trong giỏ hàng sẽ bị xóa.<br>Hành động này không thể hoàn tác.
    </p>

    <!-- Actions -->
    <div class="flex gap-3">
      <button onclick="closeClearModal()"
              class="flex-1 py-3 rounded-xl border border-outline-variant font-label-md text-on-surface hover:bg-surface-container transition-colors">
        Hủy bỏ
      </button>
      <button onclick="confirmClearCart()"
              class="flex-1 py-3 rounded-xl bg-error text-on-error font-label-md hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-[18px]">delete_forever</span>
        Xóa tất cả
      </button>
    </div>
  </div>
</div>

<style>
  #clear-modal-backdrop.modal-visible {
    background: rgba(0, 0, 0, 0.45) !important;
    backdrop-filter: blur(4px) !important;
  }
  #clear-modal-card.card-visible {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }
</style>

<%- include('partials/footer') %>
