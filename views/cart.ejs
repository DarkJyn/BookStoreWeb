<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12">

<!-- Page Title -->
<div class="mb-12">
<h1 class="font-display-lg text-display-lg text-primary mb-2">Your Shopping Cart</h1>
<p class="font-body-md text-body-md text-on-surface-variant">Review your selection of literary treasures.</p>
</div>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter-desktop items-start">
<!-- Main Cart Table Area -->
<div class="lg:col-span-8">
<div class="bg-surface-container-lowest rounded-xl shadow-[0px_4px_20px_rgba(74,69,65,0.06)] overflow-hidden">
<!-- Table Header (Desktop Only) -->
<div class="hidden md:grid grid-cols-12 gap-4 px-8 py-4 border-b border-outline-variant bg-surface-container-low font-label-md text-on-surface-variant">
<div class="col-span-6">Book Details</div>
<div class="col-span-2 text-center">Unit Price</div>
<div class="col-span-2 text-center">Quantity</div>
<div class="col-span-2 text-right">Subtotal</div>
</div>
<!-- Cart Item 1 -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-4 px-6 md:px-8 py-8 border-b border-outline-variant items-center group">
<div class="col-span-12 md:col-span-6 flex items-center space-x-6">
<div class="w-24 h-32 flex-shrink-0 bg-surface-container overflow-hidden rounded-sm shadow-sm">
<img class="w-full h-full object-cover" data-alt="A beautifully designed hardcover book cover featuring abstract botanical illustrations in muted sage green and warm cream. The title is embossed in a classic serif font, looking premium and artistic against a sun-drenched ivory background in a cozy bookstore setting." src="https://lh3.googleusercontent.com/aida-public/AB6AXuDZFcOcWSwiVs-mN93EKwx0wlKEDqv0i2LP8B3QfS8oY4DY7bVdpU_CBPdPAINFNnKxMJsb4ivGVhOy52YpXwgPeIPe5_TWPSJj5RzhbEN0Ri87dbtlOnwNz-eRVOn0afz7dsScsgh24nMwGhFqG_7hAQN-1KzBOuXzNW-zvNIEFjNhprBRSCDbyxqxLUO1saBjlKvC1oE5zV04VKUFTczb7dGYnVEiZFnwepR2egtASA8_1l0Y12D_eMlK98TO825nl5TiVEKXuS0">
</div>
<div>
<h3 class="font-headline-md text-primary leading-tight mb-1">The Midnight Library</h3>
<p class="font-body-md text-on-surface-variant text-sm">Matt Haig</p>
<p class="font-caption text-on-tertiary-fixed-variant mt-2 px-2 py-0.5 bg-tertiary-fixed inline-block rounded">Hardcover</p>
</div>
</div>
<div class="col-span-4 md:col-span-2 text-left md:text-center">
<span class="md:hidden text-caption text-on-surface-variant block mb-1">Price</span>
<span class="font-body-md text-on-surface">240.000 đ</span>
</div>
<div class="col-span-4 md:col-span-2 flex justify-center">
<div class="flex items-center border border-outline-variant rounded-lg overflow-hidden h-10">
<button class="px-2 hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-sm" data-icon="remove">remove</span></button>
<span class="px-4 font-label-md">1</span>
<button class="px-2 hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-sm" data-icon="add">add</span></button>
</div>
</div>
<div class="col-span-4 md:col-span-2 text-right flex flex-col md:block items-end">
<span class="md:hidden text-caption text-on-surface-variant block mb-1">Total</span>
<div class="flex items-center justify-end space-x-4">
<span class="font-label-md text-primary">240.000 đ</span>
<button class="text-on-surface-variant hover:text-error transition-colors opacity-0 group-hover:opacity-100">
<span class="material-symbols-outlined" data-icon="delete">delete</span>
</button>
</div>
</div>
</div>
<!-- Cart Item 2 -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-4 px-6 md:px-8 py-8 border-b border-outline-variant items-center group">
<div class="col-span-12 md:col-span-6 flex items-center space-x-6">
<div class="w-24 h-32 flex-shrink-0 bg-surface-container overflow-hidden rounded-sm shadow-sm">
<img class="w-full h-full object-cover" data-alt="A minimalist book cover design for a classic novel, featuring a single golden line drawing of a compass on a deep charcoal textured paper background. The atmosphere is intellectual and sophisticated, shot with soft side-lighting that highlights the paper grain." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBX2eCl7hXCD4BB7IkcAx-TygdG_fWDyn2fSKK5_SZ5bRlV3A8hjvqfqqpoZEUij9Mfx8nl6jnEq-9xeSiYsbj1lZFLi_ht7HAemq9YazkGSF4w4Ru2WInAKPCU-NSvroXeEHnwrSVdfhLmRTuCKVQ7cn2oQy9ZRY_FoM6gCCOZnlCa6uW1PXAJXCL159hcgNmq3o3m79sN__bSu0FDJucVCx4f8NcmVg9yvcNCG2PV-eAoKp-rIOH-QxK0y2aZfmdooyRB27eAkDQ">
</div>
<div>
<h3 class="font-headline-md text-primary leading-tight mb-1">Circe</h3>
<p class="font-body-md text-on-surface-variant text-sm">Madeline Miller</p>
<p class="font-caption text-on-tertiary-fixed-variant mt-2 px-2 py-0.5 bg-tertiary-fixed inline-block rounded">Paperback</p>
</div>
</div>
<div class="col-span-4 md:col-span-2 text-left md:text-center">
<span class="md:hidden text-caption text-on-surface-variant block mb-1">Price</span>
<span class="font-body-md text-on-surface">165.000 đ</span>
</div>
<div class="col-span-4 md:col-span-2 flex justify-center">
<div class="flex items-center border border-outline-variant rounded-lg overflow-hidden h-10">
<button class="px-2 hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-sm" data-icon="remove">remove</span></button>
<span class="px-4 font-label-md">2</span>
<button class="px-2 hover:bg-surface-container transition-colors"><span class="material-symbols-outlined text-sm" data-icon="add">add</span></button>
</div>
</div>
<div class="col-span-4 md:col-span-2 text-right flex flex-col md:block items-end">
<span class="md:hidden text-caption text-on-surface-variant block mb-1">Total</span>
<div class="flex items-center justify-end space-x-4">
<span class="font-label-md text-primary">330.000 đ</span>
<button class="text-on-surface-variant hover:text-error transition-colors opacity-0 group-hover:opacity-100">
<span class="material-symbols-outlined" data-icon="delete">delete</span>
</button>
</div>
</div>
</div>
<!-- Cart Footer Actions -->
<div class="px-8 py-6 flex justify-between items-center bg-surface-container-low">
<button class="flex items-center space-x-2 text-on-surface-variant hover:text-primary transition-colors font-label-md">
<span class="material-symbols-outlined text-sm" data-icon="arrow_back">arrow_back</span>
<span>Continue Shopping</span>
</button>
<button class="text-primary hover:underline font-label-md">Clear All Items</button>
</div>
</div>
<!-- Empty State (Hidden by default, shown for logic demonstration) -->
