<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<main class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop py-12 min-h-screen">

<div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter-desktop items-start">

  <!-- ===== LEFT: CHECKOUT FORM ===== -->
  <div class="lg:col-span-7 space-y-10">

    <!-- Section 1: Shipping Info -->
    <section class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_4px_20px_rgba(74,69,65,0.06)] border border-outline-variant/30">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-md text-label-md flex-shrink-0">1</span>
        <h2 class="font-headline-lg text-headline-lg text-primary">Thông tin giao hàng</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Full Name -->
        <div class="flex flex-col gap-1.5">
          <label for="inp-name" class="font-label-md text-label-md text-on-surface-variant">
            Họ và tên <span class="text-error">*</span>
          </label>
          <input id="inp-name" name="name" type="text"
            class="h-12 px-4 border border-outline-variant bg-surface-container-lowest rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-outline-variant"
            placeholder="Nguyễn Văn A"
            autocomplete="name"
            value="<%= userDoc.name || '' %>">
          <p id="err-name" class="text-error text-sm hidden"></p>
        </div>

        <!-- Phone -->
        <div class="flex flex-col gap-1.5">
          <label for="inp-phone" class="font-label-md text-label-md text-on-surface-variant">
            Số điện thoại <span class="text-error">*</span>
          </label>
          <input id="inp-phone" name="phone" type="tel"
            class="h-12 px-4 border border-outline-variant bg-surface-container-lowest rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-outline-variant"
            placeholder="0912 345 678"
            autocomplete="tel"
            value="<%= userDoc.phone || '' %>">
          <p id="err-phone" class="text-error text-sm hidden"></p>
        </div>

        <!-- Email -->
        <div class="md:col-span-2 flex flex-col gap-1.5">
          <label for="inp-email" class="font-label-md text-label-md text-on-surface-variant">
            Email <span class="text-error">*</span>
          </label>
          <input id="inp-email" name="email" type="email"
            class="h-12 px-4 border border-outline-variant bg-surface-container-lowest rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-outline-variant"
            placeholder="example@email.com"
            autocomplete="email"
            value="<%= userDoc.email || '' %>">
          <p id="err-email" class="text-error text-sm hidden"></p>
        </div>

        <!-- Address -->
        <div class="md:col-span-2 flex flex-col gap-1.5">
          <label for="inp-address" class="font-label-md text-label-md text-on-surface-variant">
            Địa chỉ giao hàng <span class="text-error">*</span>
          </label>
          <textarea id="inp-address" name="address" rows="3"
            class="p-4 border border-outline-variant bg-surface-container-lowest rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-outline-variant resize-none"
            placeholder="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành phố"
            autocomplete="street-address"><%= userDoc.address || '' %></textarea>
          <p id="err-address" class="text-error text-sm hidden"></p>
        </div>

        <!-- Note (optional) -->
        <div class="md:col-span-2 flex flex-col gap-1.5">
          <label for="inp-note" class="font-label-md text-label-md text-on-surface-variant">
            Ghi chú cho đơn hàng <span class="text-xs text-outline-variant">(không bắt buộc)</span>
          </label>
          <textarea id="inp-note" name="note" rows="2"
            class="p-4 border border-outline-variant bg-surface-container-lowest rounded-lg focus:ring-1 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-outline-variant resize-none"
            placeholder="Ví dụ: Giao giờ hành chính, gọi trước khi giao..."></textarea>
        </div>
      </div>
    </section>

    <!-- Section 2: Payment Method -->
    <section class="bg-surface-container-lowest rounded-xl p-8 shadow-[0px_4px_20px_rgba(74,69,65,0.06)] border border-outline-variant/30">
      <div class="flex items-center gap-4 mb-8">
        <span class="w-10 h-10 rounded-full bg-primary text-on-primary flex items-center justify-center font-label-md text-label-md flex-shrink-0">2</span>
        <h2 class="font-headline-lg text-headline-lg text-primary">Phương thức thanh toán</h2>
      </div>

      <div class="space-y-3" id="payment-options">

        <!-- COD -->
        <label id="lbl-cod"
          class="flex items-center p-4 border-2 border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-colors payment-label">
          <input type="radio" name="payment" value="cod"
            class="w-5 h-5 text-primary focus:ring-primary border-outline-variant"
            onchange="onPaymentChange(this)">
          <div class="ml-4 flex flex-col">
            <span class="font-label-md text-label-md text-on-surface">Thanh toán khi nhận hàng (COD)</span>
            <span class="font-caption text-caption text-on-surface-variant">Thanh toán bằng tiền mặt khi nhận sách.</span>
          </div>
          <span class="material-symbols-outlined ml-auto text-on-surface-variant" style="font-variation-settings:'FILL' 0">local_shipping</span>
        </label>

        <!-- Bank Transfer -->
        <label id="lbl-bank"
          class="flex items-center p-4 border-2 border-primary bg-surface-container-low rounded-xl cursor-pointer transition-colors payment-label">
          <input type="radio" name="payment" value="bank" checked
            class="w-5 h-5 text-primary focus:ring-primary border-outline-variant"
            onchange="onPaymentChange(this)">
          <div class="ml-4 flex flex-col">
            <span class="font-label-md text-label-md text-on-surface">Chuyển khoản ngân hàng</span>
            <span class="font-caption text-caption text-on-surface-variant">Chuyển khoản qua ứng dụng ngân hàng.</span>
          </div>
          <span class="material-symbols-outlined ml-auto text-primary" style="font-variation-settings:'FILL' 0">account_balance</span>
        </label>

        <!-- Bank Transfer Info (shown when bank is selected) -->
        <div id="bank-info" class="ml-2 p-5 bg-surface-container-low border border-outline-variant rounded-xl space-y-3 text-sm">
          <p class="font-label-md text-on-surface mb-3">Thông tin chuyển khoản:</p>
          <div class="grid grid-cols-2 gap-x-4 gap-y-2 font-body-md">
            <span class="text-on-surface-variant">Ngân hàng:</span>
            <span class="text-on-surface font-medium">Vietcombank</span>
            <span class="text-on-surface-variant">Số tài khoản:</span>
            <span class="text-primary font-medium tracking-wider">1234 5678 9012</span>
            <span class="text-on-surface-variant">Chủ tài khoản:</span>
            <span class="text-on-surface font-medium">CONG TY THE OPEN FOLIO</span>
          </div>
          <div class="mt-3 p-3 bg-tertiary-fixed rounded-lg">
            <p class="font-caption text-on-surface-variant">
              <span class="material-symbols-outlined text-[14px] align-middle">info</span>
              Nội dung chuyển khoản: <strong id="bank-transfer-content" class="text-on-surface">ORD-[Mã đơn hàng] - [Họ tên]</strong>
            </p>
          </div>
        </div>

        <!-- Digital Wallet -->
        <label id="lbl-wallet"
          class="flex items-center p-4 border-2 border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-colors payment-label">
          <input type="radio" name="payment" value="wallet"
            class="w-5 h-5 text-primary focus:ring-primary border-outline-variant"
            onchange="onPaymentChange(this)">
          <div class="ml-4 flex flex-col">
            <span class="font-label-md text-label-md text-on-surface">Ví điện tử</span>
            <span class="font-caption text-caption text-on-surface-variant">MoMo, ZaloPay, VNPay...</span>
          </div>
          <span class="material-symbols-outlined ml-auto text-on-surface-variant" style="font-variation-settings:'FILL' 0">wallet</span>
        </label>
      </div>
    </section>

    <!-- Submit Button (mobile: show here too) -->
    <div class="lg:hidden">
      <button id="submit-btn-mobile" onclick="submitOrder()"
        class="w-full py-4 bg-primary text-on-primary rounded-xl font-label-md text-lg hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
        <span>Xác nhận đặt hàng</span>
        <span class="material-symbols-outlined text-[18px]">check_circle</span>
      </button>
    </div>
  </div>

  <!-- ===== RIGHT: ORDER SUMMARY ===== -->
  <div class="lg:col-span-5">
    <div class="sticky top-24 bg-surface-container-lowest p-8 rounded-xl shadow-[0px_4px_20px_rgba(74,69,65,0.06)] border border-outline-variant/30">
      <h3 class="font-headline-md text-primary mb-6">Tóm tắt đơn hàng</h3>

      <!-- Empty cart warning -->
      <div id="checkout-empty" class="hidden text-center py-8">
        <span class="material-symbols-outlined text-[48px] text-outline-variant block mb-3">shopping_basket</span>
        <p class="font-body-md text-on-surface-variant mb-4">Giỏ hàng trống. Đang chuyển hướng...</p>
      </div>

      <!-- Items list -->
      <div id="checkout-items" class="space-y-4 mb-6 max-h-72 overflow-y-auto pr-1"></div>

      <!-- Totals -->
      <div id="checkout-totals" class="border-t border-outline-variant pt-5 space-y-3">
        <div class="flex justify-between font-body-md text-body-md text-on-surface-variant">
          <span>Tạm tính</span>
          <span id="co-subtotal">0 đ</span>
        </div>
        <div class="flex justify-between font-body-md text-body-md text-on-surface-variant">
          <span>Phí giao hàng</span>
          <span id="co-shipping">30.000 đ</span>
        </div>
        <div class="flex justify-between font-body-md text-body-md text-on-surface-variant">
          <span>Thuế (10%)</span>
          <span id="co-tax">0 đ</span>
        </div>
        <div class="flex justify-between font-headline-md text-headline-md text-primary pt-3 border-t border-outline-variant">
          <span>Tổng cộng</span>
          <span id="co-total">0 đ</span>
        </div>
      </div>

      <!-- Submit button (desktop) -->
      <button id="submit-btn" onclick="submitOrder()"
        class="w-full h-14 mt-8 bg-primary text-on-primary rounded-xl font-label-md text-lg hover:opacity-95 active:scale-[0.98] transition-all flex items-center justify-center gap-2">
        <span>Xác nhận đặt hàng</span>
        <span class="material-symbols-outlined text-[18px]">check_circle</span>
      </button>

      <p class="text-center mt-4 font-caption text-caption text-on-surface-variant flex items-center justify-center gap-1">
        <span class="material-symbols-outlined text-[14px]">lock</span>
        Thanh toán được mã hoá SSL
      </p>
    </div>
  </div>

</div>
</main>

<!-- ===== SUCCESS MODAL ===== -->
<div id="success-modal-backdrop"
     class="hidden fixed inset-0 z-[100] flex items-center justify-center p-4"
     style="background: rgba(0,0,0,0); backdrop-filter: blur(0px); transition: background 0.3s ease, backdrop-filter 0.3s ease;">

  <div id="success-modal-card"
       class="bg-surface-container-lowest rounded-2xl shadow-2xl w-full max-w-lg p-10 border border-outline-variant text-center"
       style="opacity:0; transform: translateY(24px) scale(0.96); transition: opacity 0.3s ease, transform 0.3s ease;">

    <!-- Animated check icon -->
    <div class="flex justify-center mb-6">
      <div class="w-20 h-20 rounded-full bg-secondary-fixed flex items-center justify-center">
        <span class="material-symbols-outlined text-secondary text-[48px]" style="font-variation-settings:'FILL' 1">check_circle</span>
      </div>
    </div>

    <h2 class="font-headline-lg text-primary mb-2">Đặt hàng thành công!</h2>
    <p class="font-body-md text-on-surface-variant mb-6">Cảm ơn bạn đã tin tưởng The Open Folio. Chúng tôi sẽ liên hệ xác nhận đơn hàng sớm nhất.</p>

    <!-- Order details -->
    <div class="bg-surface-container-low rounded-xl p-5 text-left space-y-3 mb-8">
      <div class="flex justify-between font-body-md">
        <span class="text-on-surface-variant">Mã đơn hàng</span>
        <span id="modal-order-id" class="text-primary font-medium tracking-wider"></span>
      </div>
      <div class="flex justify-between font-body-md">
        <span class="text-on-surface-variant">Người nhận</span>
        <span id="modal-name" class="text-on-surface font-medium"></span>
      </div>
      <div class="flex justify-between font-body-md">
        <span class="text-on-surface-variant">Số điện thoại</span>
        <span id="modal-phone" class="text-on-surface"></span>
      </div>
      <div class="flex justify-between font-body-md">
        <span class="text-on-surface-variant">Thanh toán</span>
        <span id="modal-payment" class="text-on-surface"></span>
      </div>
      <div class="flex justify-between font-headline-md text-primary pt-2 border-t border-outline-variant">
        <span>Tổng tiền</span>
        <span id="modal-total"></span>
      </div>
    </div>

    <button onclick="onOrderDone()"
      class="w-full py-4 bg-primary text-on-primary rounded-xl font-label-md text-lg hover:opacity-90 active:scale-95 transition-all flex items-center justify-center gap-2">
      <span class="material-symbols-outlined text-[18px]">storefront</span>
      Tiếp tục mua sắm
    </button>
  </div>
</div>

<style>
  #success-modal-backdrop.modal-open {
    background: rgba(0,0,0,0.5) !important;
    backdrop-filter: blur(6px) !important;
  }
  #success-modal-card.modal-open {
    opacity: 1 !important;
    transform: translateY(0) scale(1) !important;
  }
  /* Scrollbar for items list */
  #checkout-items::-webkit-scrollbar { width: 4px; }
  #checkout-items::-webkit-scrollbar-track { background: transparent; }
  #checkout-items::-webkit-scrollbar-thumb { background: var(--md-sys-color-outline-variant, #ccc); border-radius: 2px; }
  /* Inline error state */
  .field-error { border-color: var(--md-sys-color-error, #ba1a1a) !important; }
</style>

<script>
const SHIPPING_FEE = 30000;
const TAX_RATE     = 0.10;

// ============ FORMAT ============
function fmtVND(n) {
  return new Intl.NumberFormat('vi-VN').format(Math.round(n)) + ' đ';
}

// ============ PAYMENT LABEL TOGGLE ============
function onPaymentChange(radio) {
  document.querySelectorAll('.payment-label').forEach(lbl => {
    lbl.classList.remove('border-primary', 'bg-surface-container-low');
    lbl.classList.add('border-outline-variant');
  });
  const parent = radio.closest('label');
  parent.classList.add('border-primary', 'bg-surface-container-low');
  parent.classList.remove('border-outline-variant');

  const bankInfo = document.getElementById('bank-info');
  if (radio.value === 'bank') {
    bankInfo.classList.remove('hidden');
  } else {
    bankInfo.classList.add('hidden');
  }
}

// ============ RENDER ORDER SUMMARY ============
function renderOrderSummary() {
  const cart       = getCart();
  const emptyEl    = document.getElementById('checkout-empty');
  const itemsEl    = document.getElementById('checkout-items');
  const totalsEl   = document.getElementById('checkout-totals');
  const submitBtn  = document.getElementById('submit-btn');
  const submitBtnM = document.getElementById('submit-btn-mobile');

  if (!cart || cart.length === 0) {
    emptyEl.classList.remove('hidden');
    itemsEl.classList.add('hidden');
    totalsEl.classList.add('hidden');
    if (submitBtn)  submitBtn.disabled = true;
    if (submitBtnM) submitBtnM.disabled = true;
    setTimeout(() => { window.location.href = '/cart'; }, 1800);
    return;
  }

  itemsEl.innerHTML = cart.map(item => `
    <div class="flex gap-4 items-start">
      <div class="relative flex-shrink-0">
        <img src="${item.coverImage || ''}" alt="${escHtml(item.title)}"
             class="w-14 h-20 object-cover rounded-lg shadow-sm"
             onerror="this.style.display='none'">
        <span class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-primary text-on-primary text-[10px] font-bold rounded-full flex items-center justify-center">${item.quantity}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="font-label-md text-on-surface line-clamp-2 leading-tight">${escHtml(item.title)}</p>
        <p class="font-caption text-on-surface-variant italic text-xs mt-0.5">${escHtml(item.author || '')}</p>
      </div>
      <span class="font-label-md text-primary whitespace-nowrap flex-shrink-0">${fmtVND(item.price * item.quantity)}</span>
    </div>
  `).join('');

  const subtotal = getCartTotal();
  const tax      = subtotal * TAX_RATE;
  const total    = subtotal + SHIPPING_FEE + tax;

  document.getElementById('co-subtotal').textContent = fmtVND(subtotal);
  document.getElementById('co-tax').textContent      = fmtVND(tax);
  document.getElementById('co-total').textContent    = fmtVND(total);
}

function escHtml(str) {
  return String(str)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ============ FIELD HELPERS ============
function setFieldOk(inputEl, errEl) {
  inputEl.classList.remove('field-error');
  errEl.textContent = '';
  errEl.classList.add('hidden');
}

function setFieldErr(inputEl, errEl, msg) {
  inputEl.classList.add('field-error');
  errEl.textContent = msg;
  errEl.classList.remove('hidden');
}

// ============ VALIDATE FORM ============
function validateForm() {
  let valid = true;
  let firstErrEl = null;

  const name    = document.getElementById('inp-name');
  const phone   = document.getElementById('inp-phone');
  const email   = document.getElementById('inp-email');
  const address = document.getElementById('inp-address');

  const errName    = document.getElementById('err-name');
  const errPhone   = document.getElementById('err-phone');
  const errEmail   = document.getElementById('err-email');
  const errAddress = document.getElementById('err-address');

  // Name
  if (!name.value.trim() || name.value.trim().length < 2) {
    setFieldErr(name, errName, 'Vui lòng nhập họ và tên (ít nhất 2 ký tự).');
    valid = false; if (!firstErrEl) firstErrEl = name;
  } else { setFieldOk(name, errName); }

  // Phone — Vietnamese regex: 0[3-9] followed by 8 digits
  const phoneRegex = /^0[3-9]\d{8}$/;
  const phoneVal   = phone.value.replace(/[\s\-\.]/g, '');
  if (!phoneRegex.test(phoneVal)) {
    setFieldErr(phone, errPhone, 'Số điện thoại không hợp lệ (VD: 0912 345 678).');
    valid = false; if (!firstErrEl) firstErrEl = phone;
  } else { setFieldOk(phone, errPhone); }

  // Email
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  if (!emailRegex.test(email.value.trim())) {
    setFieldErr(email, errEmail, 'Địa chỉ email không hợp lệ.');
    valid = false; if (!firstErrEl) firstErrEl = email;
  } else { setFieldOk(email, errEmail); }

  // Address
  if (!address.value.trim()) {
    setFieldErr(address, errAddress, 'Vui lòng nhập địa chỉ giao hàng.');
    valid = false; if (!firstErrEl) firstErrEl = address;
  } else { setFieldOk(address, errAddress); }

  if (firstErrEl) {
    firstErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    firstErrEl.focus();
  }

  return valid;
}

// ============ SUBMIT ORDER ============
async function submitOrder() {
  if (!validateForm()) return;

  const cart       = getCart();
  const subtotal   = getCartTotal();
  const tax        = subtotal * TAX_RATE;
  const total      = subtotal + SHIPPING_FEE + tax;
  const payment    = document.querySelector('input[name="payment"]:checked').value;

  const customer = {
    name:    document.getElementById('inp-name').value.trim(),
    phone:   document.getElementById('inp-phone').value.trim(),
    email:   document.getElementById('inp-email').value.trim(),
    address: document.getElementById('inp-address').value.trim(),
    note:    document.getElementById('inp-note').value.trim(),
  };

  // Disable nút trong khi gửi
  const btns = [document.getElementById('submit-btn'), document.getElementById('submit-btn-mobile')];
  btns.forEach(b => { if (b) { b.disabled = true; b.textContent = 'Đang xử lý...'; } });

  try {
    const res = await fetch('/orders', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ customer, items: cart, subtotal, shipping: SHIPPING_FEE, tax, total, paymentMethod: payment })
    });

    const data = await res.json();

    if (!data.success) {
      if (typeof showToast === 'function') showToast('❌ ' + data.message);
      btns.forEach(b => { if (b) { b.disabled = false; b.textContent = 'Xác nhận đặt hàng'; } });
      return;
    }

    const orderId = data.orderId;

    // Lưu thêm vào localStorage cho tab lịch sử đơn hàng
    const order = { orderId, createdAt: new Date().toISOString(), customer, paymentMethod: payment,
      items: cart, subtotal, shipping: SHIPPING_FEE, tax, total };
    const orders = JSON.parse(localStorage.getItem('lh_orders') || '[]');
    orders.push(order);
    localStorage.setItem('lh_orders', JSON.stringify(orders));

    // Populate modal
    const paymentLabels = { cod: 'Thanh toán khi nhận hàng', bank: 'Chuyển khoản ngân hàng', wallet: 'Ví điện tử' };
    document.getElementById('modal-order-id').textContent  = orderId;
    document.getElementById('modal-name').textContent      = customer.name;
    document.getElementById('modal-phone').textContent     = customer.phone;
    document.getElementById('modal-payment').textContent   = paymentLabels[payment] || payment;
    document.getElementById('modal-total').textContent     = fmtVND(total);

    // Mở modal thành công
    const backdrop = document.getElementById('success-modal-backdrop');
    const card     = document.getElementById('success-modal-card');
    backdrop.classList.remove('hidden');
    requestAnimationFrame(() => {
      backdrop.classList.add('modal-open');
      card.classList.add('modal-open');
    });

  } catch (err) {
    if (typeof showToast === 'function') showToast('❌ Không thể kết nối máy chủ.');
    btns.forEach(b => { if (b) { b.disabled = false; b.textContent = 'Xác nhận đặt hàng'; } });
  }
}

// ============ POST ORDER ACTION ============
function onOrderDone() {
  clearCart();
  window.location.href = '/products';
}

// ============ LIVE VALIDATION (on blur) ============
['inp-name','inp-phone','inp-email','inp-address'].forEach(id => {
  const el = document.getElementById(id);
  if (el) el.addEventListener('blur', () => validateForm());
});

// ============ INIT ============
document.addEventListener('DOMContentLoaded', () => {
  renderOrderSummary();

  // Khởi tạo gợi ý nội dung chuyển khoản với tên đã auto-fill
  const nameEl = document.getElementById('inp-name');
  const hint   = document.getElementById('bank-transfer-content');
  if (hint && nameEl) {
    hint.textContent = 'ORD-[Mã đơn hàng] - ' + (nameEl.value.trim() || '[Họ tên]');
    nameEl.addEventListener('input', () => {
      hint.textContent = 'ORD-[Mã đơn hàng] - ' + (nameEl.value.trim() || '[Họ tên]');
    });
  }
});
</script>

