<!DOCTYPE html><html class="light" lang="vi"><%- include('partials/head', { title: "Admin" }) %>
<body class="bg-background text-on-surface selection:bg-secondary-fixed selection:text-on-secondary-fixed">
<div class="flex min-h-screen">
<!-- SideNavBar -->
<%- include('partials/sidebar', { activePage: 'import' }) %>
<!-- Main Content Area -->
<main class="admin-main">
<!-- Top Header -->
<header class="admin-page-header">
<div class="flex items-center space-x-4">
<h1 class="font-headline-md text-primary">Quản lý Nhập hàng</h1>
</div>
<div class="flex items-center space-x-6">
<div class="relative hidden md:block">
<span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
<input class="pl-10 pr-4 py-2 bg-surface-container-lowest border border-outline-variant rounded-full text-body-md focus:ring-2 focus:ring-primary focus:border-transparent outline-none w-64" placeholder="Tìm kiếm phiếu nhập..." type="text">
</div>
<div class="flex items-center space-x-3">
<span class="material-symbols-outlined text-on-surface-variant cursor-pointer hover:text-primary transition-colors">notifications</span>
<div class="h-8 w-8 rounded-full overflow-hidden border border-outline-variant">
<img class="h-full w-full object-cover" data-alt="Close-up portrait of a professional male librarian in a minimalist setting. He wears modern glasses and a neutral linen shirt. The lighting is soft and natural, emphasizing a calm, academic, and professional atmosphere consistent with a high-end intellectual bookstore environment." src="https://lh3.googleusercontent.com/aida-public/AB6AXuCpcyyW4bTOR8bDCImRJX3zP9gBQbYWvPJYO6aMAXlr2ebqp3jZH2afXvgtExgXmdM7SIAhevta0AUWqHPvaVNQBhDUjYLKzdVU0Gnadv7bz0qC-JT10X1x6H-fyVjMpDJoRBnJHtvulhUUCeUE0bSJbyhuXEjVSK6qZcBie9kVatt_AKpToOZQirrQoOXNvJPYE68WQj5vvOXOeMclS0kEMkPTc23FycVJICam3vVwJMYT7ttdOhhJti2U8Sq1RHGl84rwd_nBCgk">
</div>
</div>
</div>
</header>
<!-- Dashboard Content -->
<div class="admin-page-content space-y-8">
<!-- Quick Action Header -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
<!-- Statistics Cards -->
<div class="lg:col-span-1 space-y-4">
<div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-[0px_4px_20px_rgba(74,69,65,0.06)]">
<div class="flex justify-between items-start mb-2">
<span class="text-on-surface-variant font-label-md">Tổng giá trị nhập (Tháng)</span>
<span class="material-symbols-outlined text-secondary">payments</span>
</div>
<div class="text-headline-lg font-headline-lg text-primary">124.500.000đ</div>
<div class="flex items-center mt-2 text-secondary text-caption">
<span class="material-symbols-outlined text-sm mr-1">trending_up</span>
<span>+12% so với tháng trước</span>
</div>
</div>
</div>
<div class="lg:col-span-2 flex items-center justify-end space-x-4">
<button class="flex items-center px-6 py-3 bg-primary text-on-primary rounded-lg font-label-md hover:opacity-90 transition-all active:scale-95 shadow-sm">
<span class="material-symbols-outlined mr-2">add</span> Lập Phiếu Nhập Mới
                        </button>
<button class="flex items-center px-6 py-3 border border-primary text-primary rounded-lg font-label-md hover:bg-surface-variant transition-all">
<span class="material-symbols-outlined mr-2">download</span> Xuất Báo Cáo
                        </button>
</div>
</div>
<div class="grid grid-cols-1 xl:grid-cols-12 gap-gutter-desktop">
<!-- Left: Form Section -->
<section class="xl:col-span-5 space-y-6">
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-[0px_4px_20px_rgba(74,69,65,0.06)] overflow-hidden">
<div class="p-6 border-b border-outline-variant flex items-center">
<span class="material-symbols-outlined text-primary mr-3">note_add</span>
<h2 class="font-headline-md text-primary text-lg">Tạo Phiếu Nhập Mới</h2>
</div>
<form class="p-6 space-y-6">
<!-- Supplier Selection -->
<div class="space-y-2">
<label class="font-label-md text-on-surface-variant block">Nhà Cung Cấp</label>
<div class="relative">
<select class="w-full bg-surface-container-low border border-outline-variant rounded-lg p-3 text-body-md focus:ring-1 focus:ring-primary outline-none appearance-none">
<option>Nhà xuất bản Trẻ</option>
<option>Công ty Văn hóa Phương Nam</option>
<option>Nhà sách Fahasa</option>
</select>
<span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-on-surface-variant">expand_more</span>
</div>
</div>
<!-- Book Items Table (Dynamic Form) -->
<div class="space-y-4">
<div class="flex justify-between items-center">
<label class="font-label-md text-on-surface-variant">Chi tiết mặt hàng</label>
<button class="text-secondary font-label-md flex items-center hover:underline" type="button">
<span class="material-symbols-outlined text-sm mr-1">add_circle</span> Thêm sách
                                        </button>
</div>
<div class="space-y-3">
<!-- Line Item 1 -->
<div class="p-4 bg-surface-container-low rounded-lg border border-outline-variant space-y-3">
<div class="flex justify-between items-start">
<div class="font-label-md text-primary">Hành trình về Phương Đông</div>
<button class="text-error opacity-70 hover:opacity-100 transition-opacity">
<span class="material-symbols-outlined">delete</span>
</button>
</div>
<div class="grid grid-cols-3 gap-3">
<div>
<span class="text-caption text-on-surface-variant mb-1 block">Số lượng</span>
<input class="w-full bg-background border border-outline-variant rounded p-2 text-body-md focus:ring-primary outline-none" type="number" value="10">
</div>
<div>
<span class="text-caption text-on-surface-variant mb-1 block">Giá nhập</span>
<input class="w-full bg-background border border-outline-variant rounded p-2 text-body-md focus:ring-primary outline-none text-right" type="text" value="85,000">
</div>
<div class="text-right flex flex-col justify-end pb-2">
<span class="text-caption text-on-surface-variant mb-1 block">Thành tiền</span>
<span class="font-label-md">850,000đ</span>
</div>
</div>
</div>
<!-- Line Item 2 -->
<div class="p-4 bg-surface-container-low rounded-lg border border-outline-variant space-y-3 opacity-60">
<div class="text-body-md text-on-surface-variant italic">Tìm kiếm và thêm đầu sách mới...</div>
</div>
</div>
</div>
<!-- Summary -->
<div class="pt-6 border-t border-outline-variant space-y-3">
<div class="flex justify-between items-center text-body-md">
<span class="text-on-surface-variant">Tạm tính:</span>
<span>850,000đ</span>
</div>
<div class="flex justify-between items-center text-body-md">
<span class="text-on-surface-variant">Chiết khấu (0%):</span>
<span>0đ</span>
</div>
<div class="flex justify-between items-center font-label-md text-lg pt-2">
<span class="text-primary">TỔNG CỘNG:</span>
<span class="text-primary">850,000đ</span>
</div>
</div>
<button class="w-full py-4 bg-primary text-on-primary rounded-lg font-label-md text-lg shadow-sm hover:opacity-95 transition-all" type="submit">
                                    Xác Nhận Nhập Hàng
                                </button>
</form>
</div>
</section>
<!-- Right: Table Section -->
<section class="xl:col-span-7 space-y-6">
<div class="bg-surface-container-lowest rounded-xl border border-outline-variant shadow-[0px_4px_20px_rgba(74,69,65,0.06)]">
