<li><a class="hover:text-primary transition-colors" href="#">Quy định kho bãi</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Báo cáo tồn kho</a></li>
</ul>
</div>
<div>
<h4 class="font-label-md text-primary mb-4 uppercase tracking-wider">Hỗ trợ</h4>
<ul class="space-y-2 text-body-md text-on-surface-variant">
<li><a class="hover:text-primary transition-colors" href="#">Kỹ thuật hệ thống</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Phản hồi lỗi</a></li>
<li><a class="hover:text-primary transition-colors" href="#">Liên hệ Admin</a></li>
</ul>
</div>
<div class="text-right">
<p class="text-caption text-on-surface-variant">© 2024 The Open Folio. All rights reserved.</p>
<div class="flex justify-end space-x-4 mt-4">
<span class="material-symbols-outlined text-on-surface-variant opacity-60">share</span>
