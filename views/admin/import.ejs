<tr class="bg-surface-container-low">
<th class="px-6 py-4 font-label-md text-on-surface-variant border-b border-outline-variant">Mã Phiếu</th>
<th class="px-6 py-4 font-label-md text-on-surface-variant border-b border-outline-variant">Ngày Nhập</th>
<th class="px-6 py-4 font-label-md text-on-surface-variant border-b border-outline-variant">Nhà Cung Cấp</th>
<th class="px-6 py-4 font-label-md text-on-surface-variant border-b border-outline-variant text-right">Tổng Tiền</th>
<th class="px-6 py-4 font-label-md text-on-surface-variant border-b border-outline-variant">Trạng Thái</th>
<th class="px-6 py-4 font-label-md text-on-surface-variant border-b border-outline-variant"></th>
</tr>
</thead>
<tbody class="divide-y divide-outline-variant">
