<!DOCTYPE html>
<html class="light" lang="vi">
<%- include('partials/head', { title }) %>
<body class="bg-background text-on-surface font-body-md antialiased">
<div class="flex min-h-screen">
<%- include('partials/sidebar', { activePage: 'books' }) %>

<main class="admin-main">
  <header class="admin-page-header">
    <div>
      <h1 class="font-headline-md text-headline-md text-primary">Quan ly sach</h1>
      <p class="text-caption text-on-surface-variant">Dang hien thi <%= books.length %> / <%= totalBooks %> dau sach</p>
    </div>
    <a href="/admin/book-form" class="h-10 px-5 rounded-full bg-primary text-on-primary font-label-md text-label-md flex items-center gap-2">
      <span class="material-symbols-outlined text-[20px]">add</span>
      Them sach
    </a>
  </header>

  <div class="admin-page-content space-y-6">
    <form class="bg-surface-container-lowest p-6 rounded-xl shadow-sm border border-outline-variant grid grid-cols-1 lg:grid-cols-[1fr_220px_220px_auto] gap-4 items-end" method="get" action="/admin/books">
      <label class="flex flex-col gap-2">
        <span class="font-label-md text-label-md text-on-surface-variant">Tim kiem</span>
        <input name="q" value="<%= filters.q || '' %>" class="h-11 rounded-lg border border-outline-variant bg-surface-container-lowest px-4 focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Ten sach, tac gia, ID, NXB">
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-label-md text-label-md text-on-surface-variant">The loai</span>
        <select name="genre" class="h-11 rounded-lg border border-outline-variant bg-surface-container-lowest px-3 focus:border-primary focus:ring-1 focus:ring-primary">
          <option value="">Tat ca</option>
          <% genres.forEach((item) => { %>
            <option value="<%= item %>" <%= filters.genre === item ? 'selected' : '' %>><%= item %></option>
          <% }) %>
        </select>
      </label>

      <label class="flex flex-col gap-2">
        <span class="font-label-md text-label-md text-on-surface-variant">Trang thai</span>
        <select name="status" class="h-11 rounded-lg border border-outline-variant bg-surface-container-lowest px-3 focus:border-primary focus:ring-1 focus:ring-primary">
          <option value="">Tat ca</option>
          <% statuses.forEach((item) => { %>
            <option value="<%= item %>" <%= filters.status === item ? 'selected' : '' %>><%= item %></option>
          <% }) %>
        </select>
      </label>

      <div class="flex gap-2">
        <button class="h-11 px-5 rounded-lg bg-primary text-on-primary font-label-md text-label-md" type="submit">Loc</button>
        <a href="/admin/books" class="h-11 px-4 rounded-lg border border-outline-variant text-primary font-label-md text-label-md flex items-center">Xoa loc</a>
      </div>
    </form>

    <div class="bg-surface-container-lowest rounded-xl shadow-sm border border-outline-variant overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-surface-container border-b border-outline-variant">
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase">Sach</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase">ID</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase">Tac gia</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase">The loai</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase text-right">Gia</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase text-center">Ton</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase">Trang thai</th>
              <th class="px-6 py-4 font-label-md text-on-surface-variant uppercase text-right">Thao tac</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-outline-variant">
            <% if (books.length === 0) { %>
              <tr>
                <td colspan="8" class="px-6 py-12 text-center text-on-surface-variant">Khong tim thay sach phu hop.</td>
              </tr>
            <% } %>

            <% books.forEach((book) => { %>
              <% const isOut = book.stockStatus === 'Out of stock' || Number(book.stock || 0) === 0; %>
              <% const stock = Number(book.stock ?? 0); %>
              <tr class="hover:bg-surface-container-low transition-colors group">
                <td class="px-6 py-4">
                  <div class="flex items-center space-x-4 min-w-[280px]">
                    <div class="w-12 h-16 rounded overflow-hidden shadow-sm flex-shrink-0 bg-surface-variant">
                      <img alt="<%= book.imageAlt || book.title %>" class="w-full h-full object-cover" src="<%= book.coverImage %>">
                    </div>
                    <div>
                      <div class="font-headline-md text-body-md text-on-surface group-hover:text-primary transition-colors"><%= book.title %></div>
                      <div class="text-caption text-on-surface-variant"><%= book.publisher || 'Chua co NXB' %><%= book.year ? `, ${book.year}` : '' %></div>
                    </div>
                  </div>
                </td>
                <td class="px-6 py-4 font-body-md text-on-surface-variant"><%= book.id %></td>
                <td class="px-6 py-4 font-body-md text-on-surface"><%= book.author %></td>
                <td class="px-6 py-4">
                  <span class="px-2 py-1 bg-primary/10 text-primary rounded-full text-caption font-label-md"><%= book.genre || 'Khac' %></span>
                </td>
                <td class="px-6 py-4 font-body-md text-on-surface text-right"><%= formatPrice(book.price) %></td>
                <td class="px-6 py-4 font-body-md <%= stock <= 5 ? 'text-error font-medium' : 'text-on-surface' %> text-center"><%= stock %></td>
                <td class="px-6 py-4">
                  <div class="flex items-center space-x-2">
                    <span class="w-2 h-2 rounded-full <%= isOut ? 'bg-outline' : stock <= 5 ? 'bg-error' : 'bg-secondary' %>"></span>
                    <span class="text-caption font-label-md <%= isOut ? 'text-on-surface-variant' : stock <= 5 ? 'text-error' : 'text-secondary' %>"><%= stock <= 5 && !isOut ? 'Low stock' : (book.stockStatus || 'In stock') %></span>
                  </div>
                </td>
                <td class="px-6 py-4 text-right">
                  <div class="flex items-center justify-end space-x-2">
                    <a href="/products/<%= book.id %>" class="p-2 hover:bg-surface-variant rounded-full text-on-surface-variant transition-colors" title="Xem" target="_blank">
                      <span class="material-symbols-outlined text-[20px]">visibility</span>
                    </a>
                    <a href="/admin/books/<%= book.id %>/edit" class="p-2 hover:bg-surface-variant rounded-full text-on-surface-variant transition-colors" title="Sua">
                      <span class="material-symbols-outlined text-[20px]">edit</span>
                    </a>
                    <form method="post" action="/admin/books/<%= book.id %>/delete" onsubmit="return confirm('Xoa sach nay?')" class="inline">
                      <button class="p-2 hover:bg-error-container hover:text-error rounded-full text-on-surface-variant transition-colors" title="Xoa" type="submit">
                        <span class="material-symbols-outlined text-[20px]">delete</span>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</main>
</div>
</body>
</html>
