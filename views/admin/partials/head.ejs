<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title><%= typeof title !== 'undefined' ? title + ' | The Open Folio Admin' : 'The Open Folio Admin' %></title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Newsreader:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            display: inline-block;
            line-height: 1;
            text-transform: none;
            letter-spacing: normal;
            word-wrap: normal;
            white-space: nowrap;
            direction: ltr;
        }
        body {
            background-color: #fff8f4;
            font-family: 'DM Sans', sans-serif;
        }
        .font-display { font-family: 'Newsreader', serif; }
        .custom-shadow { box-shadow: 0px 4px 20px rgba(74, 69, 65, 0.06); }
        .custom-shadow-hover:hover { box-shadow: 0px 8px 30px rgba(74, 69, 65, 0.12); }
        .admin-main {
            flex: 1 1 0%;
            min-width: 0;
            min-height: 100vh;
            background-color: #fff8f4;
        }
        .admin-page-header {
            min-height: 64px;
            padding: 0 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 24px;
            position: sticky;
            top: 0;
            z-index: 30;
            background: rgba(255, 248, 244, 0.92);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid #d3c4ba;
        }
        .admin-page-content {
            width: 100%;
            max-width: 1280px;
            margin: 0 auto;
            padding: 32px;
        }
        .admin-page-header h1,
        .admin-page-header h2 {
            margin: 0;
            font-family: 'Newsreader', serif;
            font-size: 24px;
            line-height: 1.3;
            font-weight: 500;
        }
        .admin-page-header p {
            margin-top: 2px;
            font-size: 14px;
            line-height: 1.4;
        }
        @media (max-width: 768px) {
            .admin-page-header,
            .admin-page-content {
                padding-left: 20px;
                padding-right: 20px;
            }
            .admin-page-header {
                align-items: flex-start;
                flex-direction: column;
                padding-top: 16px;
                padding-bottom: 16px;
            }
        }
    </style>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "secondary-fixed": "#ccebc7",
                        "on-tertiary": "#ffffff",
                        "on-secondary-fixed-variant": "#334d33",
                        "error-container": "#ffdad6",
                        "on-secondary-container": "#506b4f",
                        "primary-container": "#634832",
                        "inverse-surface": "#34302c",
                        "on-error": "#ffffff",
                        "on-secondary": "#ffffff",
                        "surface-container-high": "#efe6e1",
                        "inverse-on-surface": "#f8efe9",
                        "on-tertiary-fixed": "#2b1700",
                        "secondary-container": "#ccebc7",
                        "on-primary-container": "#ddb89c",
                        "tertiary": "#513000",
                        "outline-variant": "#d3c4ba",
                        "surface-container-low": "#fbf2ec",
                        "on-primary-fixed": "#2b1705",
                        "on-error-container": "#93000a",
                        "tertiary-fixed": "#ffddba",
                        "primary": "#4a321d",
                        "surface-bright": "#fff8f4",
                        "secondary-fixed-dim": "#b0cfad",
                        "on-background": "#1f1b18",
                        "secondary": "#4a6549",
                        "surface-container-highest": "#eae1db",
                        "surface-container-lowest": "#ffffff",
                        "on-surface-variant": "#4f453d",
                        "surface-variant": "#eae1db",
                        "outline": "#81756c",
                        "on-secondary-fixed": "#07200b",
                        "surface-container": "#f5ece6",
                        "on-primary": "#ffffff",
                        "primary-fixed": "#ffdcc2",
                        "surface-tint": "#755841",
                        "on-primary-fixed-variant": "#5b412c",
                        "surface-dim": "#e1d8d3",
                        "primary-fixed-dim": "#e5bfa3",
                        "on-tertiary-container": "#eab57a",
                        "error": "#ba1a1a",
                        "background": "#fff8f4",
                        "tertiary-fixed-dim": "#f2bc80",
                        "surface": "#fff8f4",
                        "inverse-primary": "#e5bfa3",
                        "on-surface": "#1f1b18",
                        "on-tertiary-fixed-variant": "#633f0d",
                        "tertiary-container": "#6b4614"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "spacing": {
                        "gutter-desktop": "32px",
                        "margin-mobile": "20px",
                        "margin-desktop": "64px",
                        "gutter-mobile": "16px",
                        "container-max": "1280px",
                        "base": "8px"
                    },
                    "fontFamily": {
                        "body-lg": ["DM Sans"],
                        "display-lg": ["Newsreader"],
                        "body-md": ["DM Sans"],
                        "label-md": ["DM Sans"],
                        "headline-lg": ["Newsreader"],
                        "caption": ["DM Sans"],
