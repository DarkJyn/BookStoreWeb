<%- include('partials/head', { title }) %>
<%- include('partials/header', { activePage }) %>

<main class="pt-24 pb-16 px-margin-desktop max-w-container-max mx-auto min-h-screen">

<div class="flex flex-col md:flex-row gap-gutter-desktop">
<!-- Left Sidebar Filter -->
<aside class="w-full md:w-72 flex-shrink-0">
<form action="/products" method="GET" class="sticky top-24 space-y-8">
<% if (typeof searchQuery !== 'undefined' && searchQuery) { %>
  <input type="hidden" name="search" value="<%= searchQuery %>">
<% } %>
<h2 class="font-headline-md text-headline-md text-primary border-b border-outline-variant pb-2">Bộ lọc tìm kiếm</h2>
<!-- Genre Checkboxes -->
<section>
<h3 class="font-label-md text-label-md text-on-surface mb-4">Thể loại</h3>
<div id="genreList" class="space-y-2 pr-1 transition-all duration-300" style="max-height: 192px; overflow-y: auto; scrollbar-width: thin;">
  <% 
    const genres = typeof availableGenres !== 'undefined' ? availableGenres : [];
    genres.forEach(genreName => {
      const isChecked = typeof selectedGenres !== 'undefined' && selectedGenres.includes(genreName);
  %>
  <label class="flex items-center gap-3 cursor-pointer group py-1">
    <input 
      name="genre" 
      value="<%= genreName %>" 
      <%= isChecked ? 'checked' : '' %> 
      class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary cursor-pointer flex-shrink-0" 
      type="checkbox"
      onchange="this.form.submit()"
    >
    <span class="font-body-md text-on-surface-variant group-hover:text-primary transition-colors truncate <%= isChecked ? 'text-primary font-bold' : '' %>">
      <%= genreName %>
    </span>
  </label>
  <% }); %>
</div>
<% if (genres.length > 6) { %>
<button type="button" id="toggleGenres" onclick="toggleGenreList()" class="mt-2 text-primary text-sm font-medium hover:underline flex items-center gap-1">
  <span id="toggleGenresText">Xem thêm</span>
  <span id="toggleGenresIcon" class="material-symbols-outlined text-[16px] transition-transform">expand_more</span>
</button>
<script>
  function toggleGenreList() {
    const list = document.getElementById('genreList');
    const text = document.getElementById('toggleGenresText');
    const icon = document.getElementById('toggleGenresIcon');
    const isExpanded = list.classList.contains('genre-expanded');
    if (isExpanded) {
      list.classList.remove('genre-expanded');
      list.style.maxHeight = '192px'; /* max-h-48 = 12rem = 192px */
      text.textContent = 'Xem thêm';
      icon.style.transform = 'rotate(0deg)';
    } else {
      list.classList.add('genre-expanded');
      list.style.maxHeight = '384px'; /* max-h-96 = 24rem = 384px — vẫn cuộn được */
      text.textContent = 'Thu gọn';
      icon.style.transform = 'rotate(180deg)';
    }
  }
</script>
<% } %>
</section>
<!-- Author Search -->
<section>
<h3 class="font-label-md text-label-md text-on-surface mb-4">Tác giả</h3>
<div class="relative">
<input name="author" value="<%= typeof authorQuery !== 'undefined' ? authorQuery : '' %>" class="w-full bg-white border border-outline-variant rounded-lg px-3 py-2 text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none" placeholder="Tìm theo tên tác giả..." type="text">
<button type="submit" class="absolute right-3 top-2.5 text-outline-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined text-[20px]">person_search</span>
</button>
</div>
</section>
<!-- Price Range Slider -->
<section>
<h3 class="font-label-md text-label-md text-on-surface mb-4 flex justify-between items-center">
  <span>Khoảng giá</span>
  <span id="priceLabel" class="text-primary font-bold"><%= typeof maxPrice !== 'undefined' ? formatPrice(maxPrice) : (typeof maxPriceLimit !== 'undefined' ? formatPrice(maxPriceLimit) : '9.000.000 đ') %></span>
</h3>
<input 
  id="maxPriceSlider" 
  name="maxPrice" 
  class="w-full h-1.5 bg-surface-container-highest rounded-lg appearance-none cursor-pointer accent-primary" 
  max="<%= typeof maxPriceLimit !== 'undefined' ? maxPriceLimit : 9000000 %>" 
  min="0" 
  step="50000" 
  value="<%= typeof maxPrice !== 'undefined' ? maxPrice : (typeof maxPriceLimit !== 'undefined' ? maxPriceLimit : 9000000) %>" 
  type="range"
  oninput="updatePriceLabel(this.value)"
  onchange="this.form.submit()"
>
<div class="flex justify-between mt-2 font-caption text-caption text-on-surface-variant">
  <span>0 đ</span>
  <span><%= typeof maxPriceLimit !== 'undefined' ? formatPrice(maxPriceLimit) : '9.000.000 đ' %></span>
</div>
<script>
  function updatePriceLabel(val) {
    const formatted = new Intl.NumberFormat('vi-VN').format(val) + ' đ';
    document.getElementById('priceLabel').innerText = formatted;
  }
</script>
</section>
<!-- Publisher Checkboxes -->
<section>
<h3 class="font-label-md text-label-md text-on-surface mb-4">Nhà xuất bản</h3>
<div id="publisherList" class="space-y-2 pr-1 transition-all duration-300" style="max-height: 192px; overflow-y: auto; scrollbar-width: thin;">
  <% 
    const publishers = typeof availablePublishers !== 'undefined' ? availablePublishers : [];
    publishers.forEach(pubName => {
      const isChecked = typeof selectedPublishers !== 'undefined' && selectedPublishers.includes(pubName);
  %>
  <label class="flex items-center gap-3 cursor-pointer group py-1">
    <input 
      name="publisher" 
      value="<%= pubName %>" 
      <%= isChecked ? 'checked' : '' %> 
      class="w-4 h-4 rounded border-outline-variant text-primary focus:ring-primary cursor-pointer flex-shrink-0" 
      type="checkbox"
      onchange="this.form.submit()"
    >
    <span class="font-body-md text-on-surface-variant group-hover:text-primary transition-colors truncate <%= isChecked ? 'text-primary font-bold' : '' %>">
      <%= pubName %>
    </span>
  </label>
  <% }); %>
</div>
<% if (publishers.length > 6) { %>
<button type="button" id="togglePublishers" onclick="togglePublisherList()" class="mt-2 text-primary text-sm font-medium hover:underline flex items-center gap-1">
  <span id="togglePublishersText">Xem thêm</span>
  <span id="togglePublishersIcon" class="material-symbols-outlined text-[16px] transition-transform">expand_more</span>
</button>
<script>
  function togglePublisherList() {
    const list = document.getElementById('publisherList');
    const text = document.getElementById('togglePublishersText');
    const icon = document.getElementById('togglePublishersIcon');
    const isExpanded = list.classList.contains('publisher-expanded');
    if (isExpanded) {
      list.classList.remove('publisher-expanded');
      list.style.maxHeight = '192px';
      text.textContent = 'Xem thêm';
      icon.style.transform = 'rotate(0deg)';
    } else {
      list.classList.add('publisher-expanded');
      list.style.maxHeight = '384px';
      text.textContent = 'Thu gọn';
      icon.style.transform = 'rotate(180deg)';
    }
  }
</script>
<% } %>
</section>
</form>
</aside>
<!-- Main Content Area -->
<div class="flex-1 space-y-gutter-desktop">
<!-- Sorting & View Controls -->
<div class="flex flex-col sm:flex-row justify-between items-center bg-white p-4 rounded-xl border border-outline-variant shadow-sm gap-4">
<div class="flex items-center gap-2">
<span class="font-caption text-caption text-on-surface-variant">
    <% if (totalBooks === 0) { %>
        Không tìm thấy kết quả nào phù hợp
    <% } else { %>
        Đang hiển thị <%= startIndex + 1 %>-<%= Math.min(endIndex, totalBooks) %> trong số <%= totalBooks %> kết quả
    <% } %>
</span>
</div>
<div class="flex items-center gap-4 w-full sm:w-auto">
<div class="flex-1 sm:flex-none">
<select 
  id="sortSelect"
  name="sort"
  onchange="applySortFilter(this.value)"
  class="w-full sm:w-48 bg-surface-container-low border-none rounded-lg px-3 py-2 text-label-md font-label-md focus:ring-1 focus:ring-primary cursor-pointer">
  <option value="newest" <%= (typeof sortBy !== 'undefined' && sortBy === 'newest') ? 'selected' : '' %>>Mới nhất</option>
  <option value="price_asc" <%= (typeof sortBy !== 'undefined' && sortBy === 'price_asc') ? 'selected' : '' %>>Giá: Thấp đến Cao</option>
  <option value="price_desc" <%= (typeof sortBy !== 'undefined' && sortBy === 'price_desc') ? 'selected' : '' %>>Giá: Cao đến Thấp</option>
  <option value="bestselling" <%= (typeof sortBy !== 'undefined' && sortBy === 'bestselling') ? 'selected' : '' %>>Bán chạy nhất</option>
  <option value="rating" <%= (typeof sortBy !== 'undefined' && sortBy === 'rating') ? 'selected' : '' %>>Đánh giá cao nhất</option>
</select>
<script>
  function applySortFilter(sortValue) {
    const url = new URL(window.location.href);
    url.searchParams.set('sort', sortValue);
    url.searchParams.set('page', '1');
    window.location.href = url.toString();
  }
</script>
</div>
<div class="flex gap-2">
  <button id="btn-grid" onclick="setView('grid')" title="Dạng lưới"
    class="p-2 rounded-lg material-symbols-outlined transition-all bg-primary text-on-primary">
    grid_view
  </button>
  <button id="btn-list" onclick="setView('list')" title="Dạng danh sách"
    class="p-2 rounded-lg material-symbols-outlined transition-all bg-surface-container-low text-on-surface-variant hover:bg-surface-container-high">
    view_list
  </button>
</div>
</div>
</div>
<!-- Book Grid / List -->
<div id="book-container" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-gutter-desktop">
<% if (typeof books !== 'undefined' && books.length > 0) { %>
  <% books.forEach(book => { %>

  <!-- GRID CARD -->
  <div class="book-card book-card-grid book-card-shadow bg-white p-4 rounded-xl flex flex-col group h-full">
    <a href="/products/<%= book.id %>" class="relative overflow-hidden rounded-lg mb-4 aspect-[2/3] bg-surface-container block">
      <img alt="<%= book.title %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= book.coverImage %>">
      <div class="absolute top-2 right-2 flex flex-col gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
        <button class="w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md hover:text-primary" onclick="event.preventDefault();"><span class="material-symbols-outlined text-[20px]">favorite</span></button>
      </div>
    </a>
    <div class="flex-1 flex flex-col">
      <div class="flex justify-between items-start mb-1">
        <span class="font-caption text-caption text-secondary bg-secondary-fixed px-2 py-0.5 rounded-full uppercase tracking-wider"><%= book.genre %></span>
        <div class="flex items-center text-tertiary">
          <span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="font-label-md text-label-md ml-1"><%= book.rating.toFixed(1) %></span>
        </div>
      </div>
      <a href="/products/<%= book.id %>" class="font-headline-md text-on-surface mb-1 group-hover:text-primary transition-colors line-clamp-1 hover:underline"><%= book.title %></a>
      <p class="font-body-md text-on-surface-variant mb-4"><%= book.author %></p>
      <div class="mt-auto flex items-center justify-between">
        <span class="font-headline-md text-primary"><%= formatPrice(book.price) %></span>
        <button class="flex items-center justify-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:opacity-90 active:scale-95 transition-all"
                data-book="<%= JSON.stringify({ id: book.id, title: book.title, author: book.author, price: book.price, coverImage: book.coverImage, genre: book.genre }) %>"
                onclick="if(typeof addToCart === 'function') addToCart(JSON.parse(this.getAttribute('data-book')))">
          <span class="material-symbols-outlined text-[18px]">add_shopping_cart</span>
          Thêm
        </button>
      </div>
    </div>
  </div>

  <!-- LIST CARD -->
  <div class="book-card book-card-list hidden book-card-shadow bg-white rounded-xl overflow-hidden group" style="grid-column: 1 / -1;">
    <div class="flex gap-5 p-4 min-w-0">
      <a href="/products/<%= book.id %>" class="relative flex-shrink-0 w-28 sm:w-36 rounded-lg overflow-hidden bg-surface-container block" style="aspect-ratio:2/3;">
        <img alt="<%= book.title %>" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" src="<%= book.coverImage %>">
      </a>
      <div class="flex flex-col flex-1 min-w-0 overflow-hidden">
        <div class="flex flex-wrap items-center gap-2 mb-2">
          <span class="font-caption text-caption text-secondary bg-secondary-fixed px-2 py-0.5 rounded-full uppercase tracking-wider"><%= book.genre %></span>
          <div class="flex items-center text-tertiary">
            <span class="material-symbols-outlined text-[15px]" style="font-variation-settings: 'FILL' 1;">star</span>
            <span class="font-label-md text-label-md ml-0.5"><%= book.rating.toFixed(1) %></span>
          </div>
        </div>
        <a href="/products/<%= book.id %>" class="font-headline-md text-on-surface mb-1 group-hover:text-primary transition-colors line-clamp-2 hover:underline"><%= book.title %></a>
        <p class="font-body-md text-on-surface-variant mb-2"><%= book.author %></p>
        <div class="mt-auto flex items-center justify-between gap-4 flex-wrap">
          <span class="font-headline-md text-primary"><%= formatPrice(book.price) %></span>
          <button class="flex items-center justify-center gap-2 px-4 py-2 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:opacity-90 active:scale-95 transition-all"
                  data-book="<%= JSON.stringify({ id: book.id, title: book.title, author: book.author, price: book.price, coverImage: book.coverImage, genre: book.genre }) %>"
                  onclick="if(typeof addToCart === 'function') addToCart(JSON.parse(this.getAttribute('data-book')))">
            <span class="material-symbols-outlined text-[18px]">add_shopping_cart</span>
            Thêm vào giỏ
          </button>
        </div>
      </div>
    </div>
  </div>

  <% }); %>
<% } else { %>
  <div class="col-span-full text-center py-20 bg-white rounded-xl border border-outline-variant shadow-sm flex flex-col items-center justify-center gap-4">
    <span class="material-symbols-outlined text-[64px] text-outline-variant">search_off</span>
    <p class="font-body-lg text-on-surface-variant">Không tìm thấy sách nào phù hợp với bộ lọc bạn chọn.</p>
    <a href="/products" class="px-6 py-2 bg-primary text-on-primary rounded-lg font-label-md text-label-md hover:opacity-90 transition-opacity">Xóa bộ lọc</a>
  </div>
<% } %>
</div>

<style>
  /* Smooth transition for view switch */
  #book-container { transition: none; }
  /* List view override: flex-column, ignore grid */
  #book-container.list-view {
    display: flex !important;
    flex-direction: column;
    gap: 0.75rem;
  }
</style>

<script>
  (function() {
    var STORAGE_KEY = 'lh_products_view';

    function setView(mode) {
      localStorage.setItem(STORAGE_KEY, mode);
      applyView(mode);
    }

    function applyView(mode) {
      var container = document.getElementById('book-container');
      var btnGrid   = document.getElementById('btn-grid');
      var btnList   = document.getElementById('btn-list');
      var gridCards = document.querySelectorAll('.book-card-grid');
      var listCards = document.querySelectorAll('.book-card-list');

      if (mode === 'list') {
        // Chỉ thêm list-view class để override grid bằng flex
        container.classList.add('list-view');
        // Show list cards, hide grid cards
        gridCards.forEach(function(c) { c.classList.add('hidden'); });
        listCards.forEach(function(c) { c.classList.remove('hidden'); });
        // Button states
        btnList.classList.add('bg-primary', 'text-on-primary');
        btnList.classList.remove('bg-surface-container-low', 'text-on-surface-variant', 'hover:bg-surface-container-high');
        btnGrid.classList.remove('bg-primary', 'text-on-primary');
        btnGrid.classList.add('bg-surface-container-low', 'text-on-surface-variant', 'hover:bg-surface-container-high');
      } else {
        // Chỉ xóa list-view class — grid classes vẫn còn nguyên trên HTML
        container.classList.remove('list-view');
        // Show grid cards, hide list cards
        gridCards.forEach(function(c) { c.classList.remove('hidden'); });
        listCards.forEach(function(c) { c.classList.add('hidden'); });
        // Button states
        btnGrid.classList.add('bg-primary', 'text-on-primary');
        btnGrid.classList.remove('bg-surface-container-low', 'text-on-surface-variant', 'hover:bg-surface-container-high');
        btnList.classList.remove('bg-primary', 'text-on-primary');
        btnList.classList.add('bg-surface-container-low', 'text-on-surface-variant', 'hover:bg-surface-container-high');
      }
    }

    // Expose globally for onclick handlers
    window.setView = setView;

    // Restore saved preference on load
    var saved = localStorage.getItem(STORAGE_KEY) || 'grid';
    applyView(saved);
  })();
</script>
<!-- Pagination -->
<nav class="flex justify-center items-center gap-2 pt-8">
<% 
  const searchParam = typeof searchQuery !== 'undefined' && searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '';
  const authorParam = typeof authorQuery !== 'undefined' && authorQuery ? '&author=' + encodeURIComponent(authorQuery) : '';
  const priceParam = typeof maxPrice !== 'undefined' ? '&maxPrice=' + maxPrice : '';
  const genreParams = typeof selectedGenres !== 'undefined' && selectedGenres.length > 0
    ? selectedGenres.map(g => '&genre=' + encodeURIComponent(g)).join('')
    : '';
  const publisherParams = typeof selectedPublishers !== 'undefined' && selectedPublishers.length > 0
    ? selectedPublishers.map(p => '&publisher=' + encodeURIComponent(p)).join('')
    : '';
  const sortParam = typeof sortBy !== 'undefined' && sortBy !== 'newest' ? '&sort=' + encodeURIComponent(sortBy) : '';
  const queryParams = searchParam + authorParam + priceParam + genreParams + publisherParams + sortParam;
%>
<% if (currentPage > 1) { %>
    <a href="/products?page=<%= currentPage - 1 %><%= queryParams %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container-high transition-colors"><span class="material-symbols-outlined">chevron_left</span></a>
<% } else { %>
    <button disabled class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant opacity-50 cursor-not-allowed"><span class="material-symbols-outlined">chevron_left</span></button>
<% } %>

<%
  // Tính danh sách trang cần hiển thị: trang đầu, trang cuối, và 2 trang xung quanh trang hiện tại
  const delta = 2;
  const pagesSet = new Set();
  pagesSet.add(1);
  pagesSet.add(totalPages);
  for (let i = Math.max(2, currentPage - delta); i <= Math.min(totalPages - 1, currentPage + delta); i++) {
    pagesSet.add(i);
  }
  const pagesToShow = [...pagesSet].sort((a, b) => a - b);
  let lastShown = 0;
%>
<% for (const pg of pagesToShow) { %>
    <% if (pg - lastShown > 1) { %>
        <span class="w-10 h-10 flex items-center justify-center text-on-surface-variant font-label-md">…</span>
    <% } %>
    <% if (pg === currentPage) { %>
        <button class="w-10 h-10 flex items-center justify-center rounded-lg bg-primary text-on-primary font-label-md text-label-md"><%= pg %></button>
    <% } else { %>
        <a href="/products?page=<%= pg %><%= queryParams %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container-high transition-colors font-label-md text-label-md"><%= pg %></a>
    <% } %>
    <% lastShown = pg; %>
<% } %>

<% if (currentPage < totalPages) { %>
    <a href="/products?page=<%= currentPage + 1 %><%= queryParams %>" class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant hover:bg-surface-container-high transition-colors"><span class="material-symbols-outlined">chevron_right</span></a>
<% } else { %>
    <button disabled class="w-10 h-10 flex items-center justify-center rounded-lg border border-outline-variant opacity-50 cursor-not-allowed"><span class="material-symbols-outlined">chevron_right</span></button>
<% } %>
</nav>
</div>
</div>

</main>

<%- include('partials/footer') %>
